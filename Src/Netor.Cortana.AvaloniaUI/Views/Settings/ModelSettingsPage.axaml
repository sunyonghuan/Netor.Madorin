<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Netor.Cortana.AvaloniaUI.Views.Settings.ModelSettingsPage"
             x:CompileBindings="True">

    <DockPanel>
        <!-- 顶部标题栏 -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto" Margin="16,12,16,8">
            <TextBlock Text="模型管理" FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <ComboBox x:Name="CboProvider" Classes="form-combo" MinWidth="150"
                          SelectionChanged="OnProviderChanged">
                    <ComboBoxItem Content="— 选择厂商 —" Tag="" />
                </ComboBox>
                <Button Classes="btn-secondary" Content="刷新远程模型" Click="OnFetchModelsClick" />
                <Button Classes="btn-primary" Content="+ 添加模型" Click="OnAddClick" />
            </StackPanel>
        </Grid>

        <!-- 列表/表单切换区 -->
        <Panel>
            <ScrollViewer x:Name="ListView" VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="ModelListPanel" Spacing="1" Margin="8,0">
                    <TextBlock Text="请先选择一个 AI 厂商" Foreground="{StaticResource SubtextBrush}"
                               HorizontalAlignment="Center" Margin="0,20" />
                </StackPanel>
            </ScrollViewer>

            <!-- 编辑表单 (默认隐藏) -->
            <ScrollViewer x:Name="FormView" IsVisible="False" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12" MaxWidth="500" Margin="16,0">
                <TextBlock x:Name="FormTitle" Text="添加模型" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" />

                <!-- 模型标识 -->
                <StackPanel Spacing="4">
                    <TextBlock Text="模型标识 *" Foreground="{StaticResource SubtextBrush}" FontSize="12" />
                    <TextBox x:Name="TxtName" Classes="form-input" PlaceholderText="如：deepseek-chat、gpt-4o" MaxLength="128" />
                </StackPanel>

                <!-- 显示名称 -->
                <StackPanel Spacing="4">
                    <TextBlock Text="显示名称" Foreground="{StaticResource SubtextBrush}" FontSize="12" />
                    <TextBox x:Name="TxtDisplayName" Classes="form-input" PlaceholderText="UI 展示名称（可选）" MaxLength="128" />
                </StackPanel>

                <!-- 模型类型 -->
                <StackPanel Spacing="4">
                    <TextBlock Text="模型类型" Foreground="{StaticResource SubtextBrush}" FontSize="12" />
                    <ComboBox x:Name="CboModelType" Classes="form-combo" SelectedIndex="0">
                        <ComboBoxItem Content="对话 (chat)" Tag="chat" />
                        <ComboBoxItem Content="补全 (completion)" Tag="completion" />
                        <ComboBoxItem Content="嵌入 (embedding)" Tag="embedding" />
                        <ComboBoxItem Content="视觉 (vision)" Tag="vision" />
                    </ComboBox>
                </StackPanel>

                <!-- 上下文长度 -->
                <StackPanel Spacing="4">
                    <TextBlock Text="上下文长度" Foreground="{StaticResource SubtextBrush}" FontSize="12" />
                    <NumericUpDown x:Name="NudContext" Minimum="0" Value="0" FormatString="0"
                                   Width="150" HorizontalAlignment="Left" />
                </StackPanel>

                <!-- 描述 -->
                <StackPanel Spacing="4">
                    <TextBlock Text="描述" Foreground="{StaticResource SubtextBrush}" FontSize="12" />
                    <TextBox x:Name="TxtDesc" Classes="form-input" PlaceholderText="模型描述（可选）"
                             AcceptsReturn="True" TextWrapping="Wrap" Height="60" MaxLength="1024" />
                </StackPanel>

                <!-- 开关选项 -->
                <StackPanel Orientation="Horizontal" Spacing="24">
                    <CheckBox x:Name="ChkEnabled" Content="启用" IsChecked="True"
                              Foreground="{StaticResource TextBrush}" />
                    <CheckBox x:Name="ChkDefault" Content="设为默认"
                              Foreground="{StaticResource TextBrush}" />
                </StackPanel>

                <!-- 输入能力 -->
                <StackPanel Spacing="4">
                    <TextBlock Text="输入能力" Foreground="{StaticResource SubtextBrush}" FontSize="12" />
                    <WrapPanel Orientation="Horizontal">
                        <CheckBox x:Name="ChkInText" Content="文本" IsChecked="True"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,16,0" />
                        <CheckBox x:Name="ChkInImage" Content="图片"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,16,0" />
                        <CheckBox x:Name="ChkInAudio" Content="音频"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,16,0" />
                        <CheckBox x:Name="ChkInVideo" Content="视频"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,16,0" />
                        <CheckBox x:Name="ChkInFile" Content="文件"
                                  Foreground="{StaticResource TextBrush}" />
                    </WrapPanel>
                </StackPanel>

                <!-- 输出能力 -->
                <StackPanel Spacing="4">
                    <TextBlock Text="输出能力" Foreground="{StaticResource SubtextBrush}" FontSize="12" />
                    <WrapPanel Orientation="Horizontal">
                        <CheckBox x:Name="ChkOutText" Content="文本" IsChecked="True"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,16,0" />
                        <CheckBox x:Name="ChkOutImage" Content="图片"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,16,0" />
                        <CheckBox x:Name="ChkOutAudio" Content="音频"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,16,0" />
                        <CheckBox x:Name="ChkOutVideo" Content="视频"
                                  Foreground="{StaticResource TextBrush}" />
                    </WrapPanel>
                </StackPanel>

                <!-- 交互能力 -->
                <StackPanel Spacing="4">
                    <TextBlock Text="交互能力" Foreground="{StaticResource SubtextBrush}" FontSize="12" />
                    <WrapPanel Orientation="Horizontal">
                        <CheckBox x:Name="ChkFuncCall" Content="函数调用"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,16,0" />
                        <CheckBox x:Name="ChkStreaming" Content="流式输出"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,16,0" />
                        <CheckBox x:Name="ChkSysPrompt" Content="系统提示"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,16,0" />
                        <CheckBox x:Name="ChkJsonMode" Content="JSON 模式"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,16,0" />
                        <CheckBox x:Name="ChkReasoning" Content="思考模式"
                                  Foreground="{StaticResource TextBrush}" />
                    </WrapPanel>
                </StackPanel>

                <!-- 操作按钮 -->
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                    <Button Classes="btn-secondary" Content="取消" Click="OnCancelClick" />
                    <Button Classes="btn-primary" Content="保存" Click="OnSaveClick" />
                    <Button x:Name="BtnDelete" Classes="btn-danger" Content="删除" Click="OnDeleteClick" IsVisible="False" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
        </Panel>
    </DockPanel>

</UserControl>
