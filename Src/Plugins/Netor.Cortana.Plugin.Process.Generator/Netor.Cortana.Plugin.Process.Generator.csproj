<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <IsRoslynComponent>true</IsRoslynComponent>

    <!-- NuGet 包描述（其余配置见 Directory.Build.props） -->
    <Description>Cortana Process 插件框架的 Roslyn Source Generator，自动为 [Plugin]/[Tool] 标记的代码生成 stdin/stdout 消息循环入口、强类型 Debugger 以及 plugin.json 清单文件。</Description>
    <PackageTags>cortana;plugin;process;source-generator;roslyn</PackageTags>
    <!-- 确保引用本项目会把 Generator 当作分析器加载 -->
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <DevelopmentDependency>true</DevelopmentDependency>
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" Version="5.3.0">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.3.0" PrivateAssets="all" />
  </ItemGroup>

  <!-- 打包时把 .targets 放到 build/ -->
  <ItemGroup>
    <None Include="build\**\*.targets" Pack="true" PackagePath="build" />
  </ItemGroup>

  <!-- 打包时把 Generator DLL 放到 analyzers/dotnet/cs -->
  <Target Name="_AddAnalyzerToPackage" BeforeTargets="_GetPackageFiles" AfterTargets="Build">
    <ItemGroup>
      <_PackageFiles Include="$(TargetPath)" PackagePath="analyzers/dotnet/cs" />
    </ItemGroup>
  </Target>
  <ItemGroup>
    <Compile Remove="bin\**" />
    <EmbeddedResource Remove="bin\**" />
    <None Remove="bin\**" />
  </ItemGroup>

</Project>
