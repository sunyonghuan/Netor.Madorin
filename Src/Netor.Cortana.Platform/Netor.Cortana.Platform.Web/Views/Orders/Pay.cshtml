@model Netor.Cortana.Platform.Web.Models.Orders.OrderPayViewModel
@{
    ViewData["Title"] = "支付确认";
}

<div class="content-panel mx-auto" style="max-width: 720px;">
    <span class="eyebrow">PAYMENT</span>
    <h1>支付确认</h1>
    <p class="muted-line">确认订单后即可完成资源订阅。</p>
    <dl class="row mt-4">
        <dt class="col-sm-3">订单号</dt><dd class="col-sm-9">@Model.OrderNo</dd>
        <dt class="col-sm-3">订单标题</dt><dd class="col-sm-9">@Model.Title</dd>
        <dt class="col-sm-3">支付金额</dt><dd class="col-sm-9">CNY @Model.Amount.ToString("0.00")</dd>
    </dl>
    <form method="post">
        @Html.AntiForgeryToken()
        <button class="btn btn-madorin-primary" type="submit">确认支付</button>
    </form>
</div>
