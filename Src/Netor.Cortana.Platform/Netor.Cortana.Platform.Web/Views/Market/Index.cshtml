@model Netor.Cortana.Platform.Web.Models.Market.MarketIndexViewModel
@{
    ViewData["Title"] = "资源中心";
}

<section class="market-hero reveal-up">
    <div>
        <span class="eyebrow">RESOURCE CENTER</span>
        <h1>给 AI 公司补充新岗位。</h1>
        <p>插件、技能、智能体和解决方案集中管理。需要客服、营销、运维、写作或自动化能力时，从这里加入 Madorin。</p>
    </div>
    <a class="btn btn-madorin-primary btn-lg" asp-controller="Market" asp-action="Assets">浏览全部资源</a>
</section>

<section class="resource-map section-block">
    <div class="resource-map-copy">
        <span class="eyebrow">HOW IT WORKS</span>
        <h2>资源进入工作流。</h2>
        <p>订阅后，资源可以成为岗位能力、会议专家或执行工具。本地保留缓存，线上负责版本与授权。</p>
    </div>
    <div class="resource-map-visual" aria-hidden="true">
        <div><span>资源中心</span><strong>技能 / 插件 / 智能体</strong></div>
        <i></i>
        <div><span>Madorin</span><strong>会议 / 工作流 / 交付</strong></div>
    </div>
</section>

<section class="section-block">
    <div class="section-title">
        <div>
            <span class="eyebrow">CATEGORIES</span>
            <h2>按公司岗位选择能力</h2>
        </div>
        <a asp-controller="Market" asp-action="Assets">全部资源</a>
    </div>
    <div class="row g-3">
        @foreach (var category in Model.Categories)
        {
            <div class="col-md-6 col-xl-3">
                <a class="feature-card" asp-controller="Market" asp-action="Assets" asp-route-categoryId="@category.Id">
                    <div class="feature-icon">@category.AssetCount</div>
                    <h3>@category.Name</h3>
                    <p>@category.Description</p>
                </a>
            </div>
        }
    </div>
</section>

<section class="section-block">
    <div class="section-title">
        <div>
            <span class="eyebrow">FEATURED</span>
            <h2>优先尝试这些资源</h2>
        </div>
        <a asp-controller="Market" asp-action="Assets" asp-route-sort="featured">更多推荐</a>
    </div>
    <partial name="_AssetCards" model="Model.FeaturedAssets" />
</section>

<section class="section-block">
    <div class="section-title">
        <div>
            <span class="eyebrow">NEW</span>
            <h2>新上架能力</h2>
        </div>
        <a asp-controller="Market" asp-action="Assets">查看全部</a>
    </div>
    <partial name="_AssetCards" model="Model.LatestAssets" />
</section>
