@{
    ViewData["Title"] = "隐私说明";
}

<section class="official-hero slim reveal-on-scroll">
    <div>
        <span class="eyebrow">PRIVACY</span>
        <h1>隐私说明</h1>
        <p>Madorin 尊重用户的数据边界。账号、订阅和资源加载只收集完成服务所必需的信息。</p>
    </div>
</section>

<section class="policy-grid">
    <article class="content-panel">
        <span class="policy-index">01</span>
        <h2>我们可能收集的信息</h2>
        <p>账号信息、联系方式、订单与订阅记录、资源下载记录，以及用于排查问题的基础访问日志。</p>
    </article>
    <article class="content-panel">
        <span class="policy-index">02</span>
        <h2>信息用途</h2>
        <p>用于登录认证、资源订阅、订单处理、下载授权、服务通知和安全风控。</p>
    </article>
    <article class="content-panel">
        <span class="policy-index">03</span>
        <h2>资源与本地数据</h2>
        <p>桌面端工作区、文件、插件缓存和任务上下文以客户端实际设置为准，网站不主动读取用户本地工作内容。</p>
    </article>
    <article class="content-panel">
        <span class="policy-index">04</span>
        <h2>你的选择</h2>
        <p>你可以管理账号资料、订阅和资源下载记录。涉及账号删除或数据处理请求，可通过联系我们页面提交。</p>
    </article>
</section>
