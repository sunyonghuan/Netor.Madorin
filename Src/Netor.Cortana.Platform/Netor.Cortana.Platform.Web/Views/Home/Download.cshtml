@{
    ViewData["Title"] = "客户端下载";
}

<section class="download-hero reveal-up">
    <div>
        <span class="eyebrow">DOWNLOAD</span>
        <h1>把 AI 装进你的工作区。</h1>
        <p>下载 Madorin 桌面客户端，统一接入模型、插件、记忆和资源中心，让 AI 从聊天变成执行。</p>
        <div class="hero-actions">
            <a class="btn btn-madorin-primary btn-lg" href="#downloads">立即下载</a>
            <a class="btn btn-madorin-secondary btn-lg" asp-controller="Market" asp-action="Index">先看资源中心</a>
        </div>
    </div>
    <div class="download-package" id="downloads" aria-label="客户端下载">
        <span class="package-badge">Desktop</span>
        <h2>Madorin Desktop</h2>
        <p>面向个人工作站与团队研发环境。</p>
        <div class="package-meta">
            <span>本地优先</span>
            <span>插件扩展</span>
            <span>模型自由</span>
        </div>
        <a class="btn btn-madorin-primary w-100" href="#">立即下载</a>
    </div>
</section>

<section class="section-block">
    <div class="section-title">
        <div>
            <span class="eyebrow">WHY INSTALL</span>
            <h2>不是另一个聊天窗口</h2>
        </div>
    </div>
    <div class="capability-grid compact">
        <article class="capability-card">
            <span>01</span>
            <h3>接入你的模型</h3>
            <p>OpenAI-compatible、企业网关、本地服务，统一进入一个工作入口。</p>
        </article>
        <article class="capability-card">
            <span>02</span>
            <h3>调用你的工具</h3>
            <p>文件、Office、脚本、MCP 与业务系统都能成为 AI 的可执行能力。</p>
        </article>
        <article class="capability-card">
            <span>03</span>
            <h3>沉淀你的上下文</h3>
            <p>记忆、插件结果、任务轨迹持续累积，复杂任务不再反复解释。</p>
        </article>
    </div>
</section>

<section class="spec-band">
    <div>
        <span class="eyebrow">SYSTEM</span>
        <h2>推荐环境</h2>
    </div>
    <div class="spec-grid">
        <div><strong>系统</strong><span>按可用下载包选择对应系统</span></div>
        <div><strong>网络</strong><span>用于连接模型接口与资源中心</span></div>
        <div><strong>账号</strong><span>用于订阅、下载与资源同步</span></div>
    </div>
</section>
