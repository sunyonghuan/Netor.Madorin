@{
    ViewData["Title"] = "联系我们";
}

<section class="official-hero reveal-on-scroll">
    <div>
        <span class="eyebrow">CONTACT</span>
        <h1>把你的问题交给我们。</h1>
        <p>产品咨询、合作、资源中心入驻、账号与订阅问题，都可以通过下面的入口联系 Madorin 团队。</p>
    </div>
    <div class="contact-panel">
        <span>工作日响应</span>
        <strong>产品咨询 / 商务合作 / 资源入驻</strong>
        <p>请在邮件中说明你的使用场景、联系方式和需要协助的内容。</p>
    </div>
</section>

<section class="contact-grid">
    <article class="content-panel">
        <span class="policy-index">01</span>
        <h2>产品与使用咨询</h2>
        <p>了解 Madorin 的下载、安装、账号、资源中心和使用方式。</p>
        <a href="mailto:support@netor.me">support@netor.me</a>
    </article>
    <article class="content-panel">
        <span class="policy-index">02</span>
        <h2>资源中心合作</h2>
        <p>提交插件、技能、智能体或解决方案，进入 Madorin 资源中心。</p>
        <a href="mailto:market@netor.me">market@netor.me</a>
    </article>
    <article class="content-panel">
        <span class="policy-index">03</span>
        <h2>商务合作</h2>
        <p>企业部署、渠道合作、联合解决方案和定制能力咨询。</p>
        <a href="mailto:business@netor.me">business@netor.me</a>
    </article>
</section>
