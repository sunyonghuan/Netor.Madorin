@model Netor.Cortana.Platform.Web.Models.Home.HomeIndexViewModel
@{
    ViewData["Title"] = "一人公司的 AI 团队";
    ViewData["BodyClass"] = "marketing-home";
}

<div class="landing-page">
    <section class="landing-hero">
        <div class="hero-shell">
            <div class="hero-copy reveal-on-scroll">
                <span class="eyebrow">ONE-PERSON COMPANY</span>
                <h1>
                    <span>一个人，</span>
                    <span>也有一支</span>
                    <span>AI 团队。</span>
                </h1>
                <p class="hero-lead">你定目标，Madorin 调动技术、市场、客服、策划和运营一起推进。开会、表决、拆任务、交付结果，都在一个软件里完成。</p>
                <div class="hero-actions">
                    <a class="btn btn-madorin-primary btn-lg" asp-controller="Home" asp-action="Download">立即下载</a>
                    <a class="btn btn-madorin-secondary btn-lg" href="#company">看看它能做什么</a>
                </div>
                <div class="hero-proof">
                    <span>第一次使用也顺手</span>
                    <span>AI 岗位协同</span>
                    <span>专家会议表决</span>
                    <span>方案进入工作流</span>
                    <span>能力持续进化</span>
                </div>
            </div>

            <div class="hero-stage reveal-on-scroll delay-1" aria-label="Madorin 软件截图占位">
                <div class="screen-placeholder company-screen">
                    <div class="screen-topbar">
                        <span></span>
                        <span></span>
                        <span></span>
                        <strong>Madorin 一人团队</strong>
                    </div>
                    <div class="screen-body company-body">
                        <aside class="screen-sidebar">
                            <b>AI 岗位</b>
                            <span>技术部</span>
                            <span>市场增长部</span>
                            <span>客服部</span>
                            <span>运营管理部</span>
                            <b>会议议题</b>
                            <span>产品上线战役</span>
                            <span>客户增长计划</span>
                        </aside>
                        <main class="screen-main company-main">
                            <div class="meeting-topic">议题：如何用 30 天完成一次产品发布？</div>
                            <div class="company-vote-grid">
                                <div><span>技术部</span><strong>排开发、部署、监控任务</strong></div>
                                <div><span>市场增长部</span><strong>定内容、视频、获客节奏</strong></div>
                                <div><span>客服部</span><strong>准备问答、话术、反馈入口</strong></div>
                                <div><span>运营管理部</span><strong>生成里程碑与执行清单</strong></div>
                            </div>
                            <div class="screen-response">专家会议已完成表决，正在生成《产品发布作战方案》和工作流任务。</div>
                        </main>
                    </div>
                    <div class="shot-note">截图占位 · 可替换为真实界面</div>
                </div>
            </div>
        </div>
        <div class="scroll-cue" aria-hidden="true"><span></span></div>
    </section>

    <section class="pain-section" id="company">
        <div class="wide-section">
            <div class="section-kicker reveal-on-scroll">WHAT IT CHANGES</div>
            <h2 class="display-line reveal-on-scroll">创业最累的不是没有想法，是没人和你一起扛。</h2>
            <div class="pain-grid">
                <article class="pain-card reveal-on-scroll">
                    <span>01</span>
                    <div class="pain-visual"><i></i><i></i><i></i></div>
                    <h3>岗位有人接</h3>
                    <p>技术、营销、客服、运营，不再全部压在你一个人身上。</p>
                </article>
                <article class="pain-card reveal-on-scroll delay-1">
                    <span>02</span>
                    <div class="pain-visual decision"><i></i><i></i><i></i></div>
                    <h3>决策有人辩</h3>
                    <p>专家智能体从不同角度讨论、反驳、表决，结论更可靠。</p>
                </article>
                <article class="pain-card reveal-on-scroll delay-2">
                    <span>03</span>
                    <div class="pain-visual delivery"><i></i><i></i><i></i></div>
                    <h3>结果有人推</h3>
                    <p>会议结论进入工作流，变成文档、脚本、清单和下一步。</p>
                </article>
            </div>
        </div>
    </section>

    <section class="scenario-section">
        <div class="wide-section scenario-layout">
            <div class="scenario-copy reveal-on-scroll">
                <span class="eyebrow">MEETING TO DELIVERY</span>
                <h2>开一次 AI 会议，直接形成可执行方案。</h2>
                <p>不是让一个 AI 给建议，而是让多个岗位一起判断。讨论结束后，Madorin 把结论整理成文档、任务和工作流。</p>
            </div>
            <div class="meeting-visual reveal-on-scroll delay-1" aria-label="会议到交付流程图">
                <div class="meeting-center">
                    <span>议题</span>
                    <strong>新品 30 天上线</strong>
                </div>
                <div class="expert-node node-tech"><span>技术</span><b>开发 / 部署</b></div>
                <div class="expert-node node-growth"><span>市场</span><b>获客 / 内容</b></div>
                <div class="expert-node node-care"><span>客服</span><b>话术 / 反馈</b></div>
                <div class="expert-node node-plan"><span>策划</span><b>节奏 / 风险</b></div>
                <div class="delivery-strip">
                    <span>会议纪要</span>
                    <span>执行清单</span>
                    <span>工作流</span>
                    <span>交付物</span>
                </div>
            </div>
        </div>
    </section>

    <section class="showcase-section">
        <div class="showcase-grid">
            <div class="showcase-copy reveal-on-scroll">
                <span class="eyebrow">CEO MODE</span>
                <h2>你定方向，Madorin 调团队。</h2>
                <p>输入一个业务目标，它把任务分给合适岗位：调研、方案、风险、执行同时推进。你看到的是过程，不只是回答。</p>
            </div>
            <div class="team-board reveal-on-scroll delay-1">
                <div class="team-card lead">
                    <span>你 / CEO</span>
                    <strong>定义目标，审批方向，选择最终方案</strong>
                </div>
                <div class="team-card"><span>技术部</span><strong>开发软件、维护服务器、编写脚本</strong></div>
                <div class="team-card"><span>市场增长部</span><strong>找客户、做内容、处理视频和投放节奏</strong></div>
                <div class="team-card"><span>客服部</span><strong>维护客户、整理问题、生成服务话术</strong></div>
                <div class="team-card"><span>运营管理部</span><strong>拆任务、排优先级、追踪进度</strong></div>
            </div>
        </div>
    </section>

    <section class="department-section">
        <div class="wide-section">
            <div class="section-kicker reveal-on-scroll">AI DEPARTMENTS</div>
            <h2 class="display-line reveal-on-scroll">关键岗位，随时待命。</h2>
            <div class="department-grid">
                <article class="department-card reveal-on-scroll">
                    <span>技术部</span>
                    <div class="department-visual"><i>DEV</i><i>OPS</i><i>AUTO</i></div>
                    <h3>开发、运维、自动化</h3>
                    <p>排查报错，生成脚本，辅助交付。</p>
                </article>
                <article class="department-card reveal-on-scroll delay-1">
                    <span>市场增长部</span>
                    <div class="department-visual"><i>ADS</i><i>VIDEO</i><i>LEAD</i></div>
                    <h3>内容、视频、获客</h3>
                    <p>产出脚本、节奏、增长方案。</p>
                </article>
                <article class="department-card reveal-on-scroll delay-2">
                    <span>客服部</span>
                    <div class="department-visual"><i>FAQ</i><i>CRM</i><i>CARE</i></div>
                    <h3>客户服务、反馈沉淀</h3>
                    <p>整理问题，维护话术，稳住关系。</p>
                </article>
                <article class="department-card reveal-on-scroll">
                    <span>产品策划部</span>
                    <div class="department-visual"><i>IDEA</i><i>PLAN</i><i>RISK</i></div>
                    <h3>想法变方案</h3>
                    <p>拆目标、路径、风险和里程碑。</p>
                </article>
                <article class="department-card reveal-on-scroll delay-1">
                    <span>运营管理部</span>
                    <div class="department-visual"><i>TASK</i><i>DOC</i><i>NEXT</i></div>
                    <h3>任务拆解、进度追踪</h3>
                    <p>沉淀纪要、待办和下一步。</p>
                </article>
                <article class="department-card reveal-on-scroll delay-2">
                    <span>能力扩展部</span>
                    <div class="department-visual"><i>SKILL</i><i>PLUGIN</i><i>API</i></div>
                    <h3>技能、插件、脚本</h3>
                    <p>能力不够，就继续扩展。</p>
                </article>
            </div>
        </div>
    </section>

    <section class="feature-runway">
        <div class="wide-section">
            <div class="section-kicker reveal-on-scroll">WORK MODES</div>
            <h2 class="display-line reveal-on-scroll">三种模式，应对三类工作。</h2>
            <div class="mode-grid">
                <article class="mode-card reveal-on-scroll">
                    <span>对话模式</span>
                    <div class="mode-visual chat-lines"><i></i><i></i><i></i></div>
                    <h3>随时开始</h3>
                    <p>写作、整理、解释、初稿。</p>
                </article>
                <article class="mode-card reveal-on-scroll delay-1">
                    <span>会议模式</span>
                    <div class="mode-visual meeting-dots"><i></i><i></i><i></i><i></i></div>
                    <h3>多人讨论</h3>
                    <p>决策、风险、表决、纪要。</p>
                </article>
                <article class="mode-card reveal-on-scroll delay-2">
                    <span>工作流模式</span>
                    <div class="mode-visual flow-blocks"><i></i><i></i><i></i></div>
                    <h3>持续推进</h3>
                    <p>上线、发布、维护、开发。</p>
                </article>
            </div>
        </div>
    </section>

    <section class="advantage-section">
        <div class="wide-section">
            <div class="section-kicker reveal-on-scroll">WHY MADORIN</div>
            <h2 class="display-line reveal-on-scroll">它不是另一个聊天窗口，而是一个会成长的个人组织。</h2>
            <div class="advantage-grid">
                <article class="advantage-card reveal-on-scroll">
                    <h3>第一次使用也顺手</h3>
                    <p>不用先学模型、智能体或插件。</p>
                </article>
                <article class="advantage-card reveal-on-scroll">
                    <h3>智能体就是岗位</h3>
                    <p>像组团队一样组织 AI 角色。</p>
                </article>
                <article class="advantage-card reveal-on-scroll">
                    <h3>会议能产出最终方案</h3>
                    <p>讨论、表决、纪要、清单一次完成。</p>
                </article>
                <article class="advantage-card reveal-on-scroll">
                    <h3>技能沉淀方法论</h3>
                    <p>常做的事变成可复用能力。</p>
                </article>
                <article class="advantage-card reveal-on-scroll">
                    <h3>插件补齐新能力</h3>
                    <p>脚本、工具和外部系统都能接入。</p>
                </article>
                <article class="advantage-card reveal-on-scroll">
                    <h3>多模型兼容</h3>
                    <p>选择模型，不被单一平台锁住。</p>
                </article>
            </div>
        </div>
    </section>

    <section class="flow-section">
        <div class="wide-section flow-layout">
            <div class="flow-copy reveal-on-scroll">
                <span class="eyebrow">FROM IDEA TO TEAM</span>
                <h2>说出目标，团队开始工作。</h2>
                <p>创业者、小团队、独立开发者、自由职业者，都可以用 Madorin 把想法拆成岗位、会议、工作流和交付物。</p>
            </div>
            <div class="flow-steps">
                <div class="flow-step reveal-on-scroll"><span>1</span><strong>说出业务目标</strong><p>例如：我要上线一个产品、维护客户、发布一轮营销内容。</p></div>
                <div class="flow-step reveal-on-scroll"><span>2</span><strong>选择 AI 岗位</strong><p>技术、营销、客服、策划、管理等智能体参与任务。</p></div>
                <div class="flow-step reveal-on-scroll"><span>3</span><strong>开会并形成方案</strong><p>多个专家讨论、表决、补充风险，输出最终执行文档。</p></div>
                <div class="flow-step reveal-on-scroll"><span>4</span><strong>进入工作流交付</strong><p>调用插件、脚本、文件和外部工具，把方案推进成实际结果。</p></div>
            </div>
        </div>
    </section>

    <section class="final-cta">
        <div class="wide-section final-cta-inner reveal-on-scroll">
            <div>
                <span class="eyebrow">READY</span>
                <h2>从一个人开始，带起一支 AI 团队。</h2>
                <p>下载 Madorin，把技术、市场、客服、策划和管理放进同一个软件里。</p>
            </div>
            <a class="btn btn-madorin-primary btn-lg" asp-controller="Home" asp-action="Download">立即下载</a>
        </div>
    </section>
</div>
