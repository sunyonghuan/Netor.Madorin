<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Netor.Cortana.UI.ViewModels.Workspace"
             xmlns:local="using:Netor.Cortana.UI.Views.Workspace"
             x:Class="Netor.Cortana.UI.Views.Workspace.WorkspaceTab"
             x:DataType="vm:WorkspaceTabVm"
             x:CompileBindings="True"
             Background="#1e1e1e">

    <UserControl.Styles>
        <!-- 任务列表项悬停 / 选中样式 -->
        <Style Selector="Border.task-item">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,1" />
        </Style>
        <Style Selector="Border.task-item:pointerover">
            <Setter Property="Background" Value="#252526" />
        </Style>
        <Style Selector="Border.task-item-active">
            <Setter Property="Background" Value="#2a2d2e" />
        </Style>

        <!-- 步骤项 -->
        <Style Selector="Border.step-item">
            <Setter Property="Background" Value="#252526" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="BorderBrush" Value="#3c3c3c" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <!-- 新建任务按钮 -->
        <Style Selector="Button.new-task-btn">
            <Setter Property="Background" Value="#0e639c" />
            <Setter Property="Foreground" Value="#ffffff" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.new-task-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1177bb" />
        </Style>

        <!-- 详情区操作按钮 -->
        <Style Selector="Button.detail-action-btn">
            <Setter Property="Background" Value="#3a3d41" />
            <Setter Property="Foreground" Value="#cccccc" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style Selector="Button.detail-action-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#4a4d51" />
        </Style>
        <Style Selector="Button.detail-action-btn-cancel">
            <Setter Property="Background" Value="#6e2828" />
        </Style>
        <Style Selector="Button.detail-action-btn-cancel:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#8a3838" />
        </Style>

        <!-- 占位标题灰色 -->
        <Style Selector="TextBlock.title-placeholder">
            <Setter Property="Foreground" Value="#858585" />
            <Setter Property="FontStyle" Value="Italic" />
        </Style>
    </UserControl.Styles>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="220" MaxWidth="400" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ════════════════════════════════ 左：任务列表 ════════════════════════════════ -->
        <Border Grid.Column="0" Background="#1e1e1e"
                BorderBrush="#3c3c3c" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- 顶部工具栏 -->
                <Border DockPanel.Dock="Top" Padding="10,10,10,6"
                        BorderBrush="#252526" BorderThickness="0,0,0,1">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="工作台"
                                       Foreground="#cccccc" FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <Button Classes="new-task-btn" Content="+ 新建任务"
                                Click="OnNewTaskClick" />
                    </StackPanel>
                </Border>

                <!-- 任务列表 -->
                <ScrollViewer x:Name="ListScroller"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="Transparent">
                    <ItemsControl x:Name="TaskList"
                                  ItemsSource="{Binding List.Items}"
                                  Padding="6">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:WorkflowTaskItemVm">
                                <Border Classes="task-item"
                                        Tag="{Binding TaskId}"
                                        PointerPressed="OnTaskItemPressed">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="重命名" Tag="{Binding TaskId}" Click="OnRenameClick" />
                                            <MenuItem Header="置顶 / 取消置顶" Tag="{Binding TaskId}" Click="OnTogglePinClick" />
                                            <MenuItem Header="归档" Tag="{Binding TaskId}" Click="OnArchiveClick" />
                                            <Separator />
                                            <MenuItem Header="复制为新任务" Tag="{Binding TaskId}" Click="OnDuplicateClick" />
                                            <Separator />
                                            <MenuItem Header="删除" Tag="{Binding TaskId}" Click="OnDeleteClick" />
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <StackPanel Spacing="4">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <TextBlock Grid.Column="0" Text="📌"
                                                       FontSize="11" Margin="0,0,4,0"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding IsPinned}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DisplayTitle}"
                                                       Foreground="#cccccc"
                                                       FontSize="13"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding StatusIcon}"
                                                       Foreground="{Binding StatusColorHex}"
                                                       FontSize="11"
                                                       Margin="6,0,0,0"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                        <TextBlock Text="{Binding RelativeTimeText}"
                                                   Foreground="#858585"
                                                   FontSize="11" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- 拖拽分隔条 -->
        <GridSplitter Grid.Column="1" Width="4" Background="Transparent" />

        <!-- ════════════════════════════════ 右：任务详情 ════════════════════════════════ -->
        <Border Grid.Column="2" Background="#1e1e1e">
            <Panel x:Name="DetailRoot">
                <!-- 空状态：未选中任何任务 -->
                <StackPanel x:Name="EmptyHint"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Spacing="8"
                            IsVisible="{Binding Detail.TaskId, Converter={x:Static StringConverters.IsNullOrEmpty}}">
                    <TextBlock Text="选择左侧任务查看详情，或点击「新建任务」开始一个新的 Workflow"
                               Foreground="#858585" FontSize="13" TextAlignment="Center"
                               MaxWidth="320" TextWrapping="Wrap" />
                </StackPanel>

                <!-- 详情主体 -->
                <DockPanel x:Name="DetailContent"
                           IsVisible="{Binding Detail.TaskId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">

                    <!-- ── 详情头：标题/状态/子模式/参与者 ── -->
                    <Border DockPanel.Dock="Top"
                            Background="#252526"
                            BorderBrush="#3c3c3c" BorderThickness="0,0,0,1"
                            Padding="16,12">
                        <StackPanel Spacing="6">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Detail.Title}"
                                           Foreground="#cccccc"
                                           FontSize="16" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="0">
                                    <Button x:Name="CancelButton"
                                            Classes="detail-action-btn detail-action-btn-cancel"
                                            Content="取消任务"
                                            Click="OnCancelTaskClick"
                                            IsVisible="{Binding Detail.IsRunning}" />
                                </StackPanel>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto" RowDefinitions="Auto">
                                <TextBlock Grid.Column="0" Text="状态：" Foreground="#858585" FontSize="12" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Detail.StatusText}"
                                           Foreground="#cccccc" FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0" />
                                <TextBlock Grid.Column="2" Text="耗时：" Foreground="#858585" FontSize="12" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="3" Text="{Binding Detail.DurationText}"
                                           Foreground="#cccccc" FontSize="12" VerticalAlignment="Center" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto">
                                <TextBlock Grid.Column="0" Text="子模式：" Foreground="#858585" FontSize="12" />
                                <TextBlock Grid.Column="1" Text="{Binding Detail.SubMode}"
                                           Foreground="#cccccc" FontSize="12" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── 详情主体：步骤 + 报告 ── -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
                        <StackPanel Spacing="12">
                            <!-- 步骤列表（运行/完成都展示） -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="执行过程"
                                           Foreground="#cccccc" FontSize="13" FontWeight="SemiBold" />
                                <ItemsControl ItemsSource="{Binding Detail.Steps}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Vertical" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:StepItemVm">
                                            <Border Classes="step-item">
                                                <StackPanel Spacing="4">
                                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Sequence}"
                                                                   Foreground="#858585" FontSize="11"
                                                                   Margin="0,0,8,0" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding AgentName}"
                                                                   Foreground="#cccccc" FontSize="13"
                                                                   FontWeight="SemiBold" />
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding StatusIcon}"
                                                                   Foreground="{Binding StatusColorHex}"
                                                                   FontSize="11"
                                                                   Margin="0,0,8,0"
                                                                   VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="3"
                                                                   Text="{Binding DurationText}"
                                                                   Foreground="#858585" FontSize="11"
                                                                   VerticalAlignment="Center" />
                                                    </Grid>
                                                    <TextBlock Text="{Binding Summary}"
                                                               Foreground="#9e9e9e" FontSize="12"
                                                               TextWrapping="Wrap"
                                                               IsVisible="{Binding Summary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="（暂无步骤）"
                                           Foreground="#858585" FontSize="12" FontStyle="Italic"
                                           IsVisible="False" />
                            </StackPanel>

                            <!-- 最终报告（完成时） -->
                            <StackPanel Spacing="6"
                                        IsVisible="{Binding Detail.IsCompleted}">
                                <TextBlock Text="最终报告"
                                           Foreground="#cccccc" FontSize="13" FontWeight="SemiBold" />
                                <Border Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1"
                                        CornerRadius="4" Padding="14">
                                    <SelectableTextBlock
                                        Text="{Binding Detail.FinalReport}"
                                        Foreground="#cccccc" FontSize="13"
                                        TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>

                            <!-- 错误信息（失败时） -->
                            <StackPanel Spacing="6"
                                        IsVisible="{Binding Detail.IsFailed}">
                                <TextBlock Text="失败详情"
                                           Foreground="#f48771" FontSize="13" FontWeight="SemiBold" />
                                <Border Background="#3a1f1f" BorderBrush="#6e2828" BorderThickness="1"
                                        CornerRadius="4" Padding="14">
                                    <SelectableTextBlock
                                        Text="{Binding Detail.ErrorMessage}"
                                        Foreground="#f48771" FontSize="13"
                                        TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>

                            <!-- 取消提示 -->
                            <StackPanel Spacing="6"
                                        IsVisible="{Binding Detail.IsCancelled}">
                                <TextBlock Text="该任务已被取消"
                                           Foreground="#858585" FontSize="13" FontStyle="Italic" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Panel>
        </Border>
    </Grid>
</UserControl>
