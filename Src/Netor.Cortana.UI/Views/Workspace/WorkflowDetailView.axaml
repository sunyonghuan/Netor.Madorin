<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Netor.Cortana.UI.ViewModels.Workspace"
             xmlns:controls="using:Netor.Cortana.UI.Controls"
             xmlns:entities="using:Netor.Cortana.Entitys"
             x:Class="Netor.Cortana.UI.Views.Workspace.WorkflowDetailView"
             x:DataType="vm:WorkspaceTabVm"
             x:CompileBindings="True"
             Background="#1e1e1e">

	<!-- ════════════════════════════════════════════════════════════════
	     P4 三面板布局（2026-05-24 重写）
	     ════════════════════════════════════════════════════════════════
	     Row 0: 任务标题栏 + 状态 + 操作按钮
	     Row 1: 主内容区（左：计划步骤概览 | 右：时间线事件流）
	     Row 2: 底部输入工具栏（智能体/厂商/模型/工具选择器）

	     DataContext:
	     - 根 = WorkspaceTabVm
	     - Detail 面板绑定 = WorkspaceTabVm.Detail (P4TaskDetailVm)
	     - InputArea.DataContext = WorkflowInputVm（code-behind 设置）
	     ════════════════════════════════════════════════════════════════ -->

	<UserControl.Styles>
		<!-- 步骤项 -->
		<Style Selector="Border.step-item">
			<Setter Property="Background" Value="#252526" />
			<Setter Property="CornerRadius" Value="4" />
			<Setter Property="Padding" Value="10,8" />
			<Setter Property="Margin" Value="0,2" />
			<Setter Property="BorderBrush" Value="#3c3c3c" />
			<Setter Property="BorderThickness" Value="1" />
		</Style>

		<!-- 操作按钮 -->
		<Style Selector="Button.detail-action-btn">
			<Setter Property="Background" Value="#3a3d41" />
			<Setter Property="Foreground" Value="#cccccc" />
			<Setter Property="Padding" Value="12,6" />
			<Setter Property="CornerRadius" Value="4" />
			<Setter Property="FontSize" Value="12" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Margin" Value="0,0,8,0" />
		</Style>
		<Style Selector="Button.detail-action-btn:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#4a4d51" />
		</Style>
		<Style Selector="Button.detail-action-btn-cancel">
			<Setter Property="Background" Value="#6e2828" />
		</Style>
		<Style Selector="Button.detail-action-btn-cancel:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#7a3030" />
		</Style>
		<Style Selector="Button.detail-action-btn-pause">
			<Setter Property="Background" Value="#5c4a1f" />
		</Style>
		<Style Selector="Button.detail-action-btn-pause:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#6e5a28" />
		</Style>
		<Style Selector="Button.detail-action-btn-resume">
			<Setter Property="Background" Value="#1f5c3a" />
		</Style>
		<Style Selector="Button.detail-action-btn-resume:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#287a4a" />
		</Style>

		<!-- 计划确认/审批按钮 -->
		<Style Selector="Button.approval-btn-primary">
			<Setter Property="Background" Value="#0e7c3c" />
			<Setter Property="Foreground" Value="#ffffff" />
			<Setter Property="Padding" Value="14,8" />
			<Setter Property="CornerRadius" Value="4" />
			<Setter Property="FontSize" Value="13" />
			<Setter Property="FontWeight" Value="SemiBold" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Margin" Value="0,0,8,0" />
		</Style>
		<Style Selector="Button.approval-btn-primary:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#0e9c4c" />
		</Style>
		<Style Selector="Button.approval-btn-secondary">
			<Setter Property="Background" Value="#3a3d41" />
			<Setter Property="Foreground" Value="#cccccc" />
			<Setter Property="Padding" Value="14,8" />
			<Setter Property="CornerRadius" Value="4" />
			<Setter Property="FontSize" Value="13" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Margin" Value="0,0,8,0" />
		</Style>
		<Style Selector="Button.approval-btn-secondary:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#4a4d51" />
		</Style>
		<Style Selector="Button.approval-btn-danger">
			<Setter Property="Background" Value="#6e2828" />
			<Setter Property="Foreground" Value="#ffffff" />
			<Setter Property="Padding" Value="14,8" />
			<Setter Property="CornerRadius" Value="4" />
			<Setter Property="FontSize" Value="13" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="BorderThickness" Value="0" />
		</Style>
		<Style Selector="Button.approval-btn-danger:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#8a3838" />
		</Style>

		<!-- 面板分隔线 -->
		<Style Selector="Border.panel-separator">
			<Setter Property="Background" Value="#3c3c3c" />
			<Setter Property="Width" Value="1" />
		</Style>
	</UserControl.Styles>

	<Grid x:Name="DetailRoot" RowDefinitions="Auto,*,Auto">

		<!-- ════════════════════════════════════════════════════════════════
		     Row 0: 空状态 + 任务标题栏
		     ════════════════════════════════════════════════════════════════ -->
		<Panel Grid.Row="0">
			<!-- 空状态提示（无选中任务时） -->
			<controls:EmptyState x:Name="EmptyHint"
			                     IsVisible="{Binding Detail.TaskId, Converter={x:Static StringConverters.IsNullOrEmpty}}"
			                     IconText="📋"
			                     Title="选择左侧任务查看详情"
			                     Description="左侧任务列表为空时，在下方输入框中输入任务描述并发送即可创建新任务。" />

			<!-- 任务标题栏 -->
			<Border x:Name="HeaderBar"
			        Background="#252526"
			        BorderBrush="#3c3c3c" BorderThickness="0,0,0,1"
			        Padding="16,10"
			        IsVisible="{Binding Detail.TaskId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
				<Grid ColumnDefinitions="*,Auto">
					<!-- 左：标题 + 状态 + 耗时 -->
					<StackPanel Grid.Column="0" Spacing="4">
						<StackPanel Orientation="Horizontal" Spacing="8">
							<TextBlock Text="{Binding Detail.TaskTitle}"
							           Foreground="#cccccc"
							           FontSize="15" FontWeight="SemiBold"
							           TextTrimming="CharacterEllipsis"
							           VerticalAlignment="Center"
							           MaxWidth="500" />
							<!-- 状态徽章 -->
							<Border CornerRadius="3" Padding="8,2" VerticalAlignment="Center"
							        x:CompileBindings="False">
								<Border.Background>
									<SolidColorBrush Color="{Binding Detail.StatusColor}" Opacity="0.2" />
								</Border.Background>
								<TextBlock Text="{Binding Detail.StatusText}"
								           FontSize="11" FontWeight="SemiBold"
								           x:CompileBindings="False">
									<TextBlock.Foreground>
										<SolidColorBrush Color="{Binding Detail.StatusColor}" />
									</TextBlock.Foreground>
								</TextBlock>
							</Border>
						</StackPanel>
						<StackPanel Orientation="Horizontal" Spacing="12">
							<StackPanel Orientation="Horizontal" Spacing="4">
								<TextBlock Text="耗时" Foreground="#858585" FontSize="11" />
								<TextBlock Text="{Binding Detail.DurationText}"
								           Foreground="#a0a0a0" FontSize="11" />
							</StackPanel>
							<StackPanel Orientation="Horizontal" Spacing="4"
							            IsVisible="{Binding Detail.TotalTokensText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
								<TextBlock Text="Token" Foreground="#858585" FontSize="11" />
								<TextBlock Text="{Binding Detail.TotalTokensText}"
								           Foreground="#a0a0a0" FontSize="11" />
							</StackPanel>
						</StackPanel>
					</StackPanel>

					<!-- 右：操作按钮 -->
					<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
					            VerticalAlignment="Center">
						<!-- 暂停按钮（运行中可见） -->
						<Button x:Name="PauseButton"
						        Classes="detail-action-btn detail-action-btn-pause"
						        Content="⏸ 暂停"
						        Click="OnPauseTaskClick"
						        IsVisible="{Binding Detail.IsRunning}"
						        ToolTip.Tip="暂停任务（当前步骤完成后生效）" />
						<!-- 恢复按钮（暂停时可见） -->
						<Button x:Name="ResumeButton"
						        Classes="detail-action-btn detail-action-btn-resume"
						        Content="▶ 恢复"
						        Click="OnResumeTaskClick"
						        IsVisible="{Binding Detail.IsPaused}"
						        ToolTip.Tip="恢复执行" />
						<!-- 取消按钮（运行中/暂停时可见） -->
						<Button x:Name="CancelButton"
						        Classes="detail-action-btn detail-action-btn-cancel"
						        Content="取消"
						        Click="OnCancelTaskClick" />
					</StackPanel>
				</Grid>
			</Border>
		</Panel>

		<!-- ════════════════════════════════════════════════════════════════
		     Row 1: 主内容区（左: 计划步骤 | 右: 时间线）
		     ════════════════════════════════════════════════════════════════ -->
		<Grid Grid.Row="1" ColumnDefinitions="220,Auto,*"
		      IsVisible="{Binding Detail.TaskId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">

			<!-- ── 左面板: 计划步骤概览 ── -->
			<Border Grid.Column="0" Background="#1e1e1e" Padding="0">
				<DockPanel>
					<!-- 面板标题 -->
					<Border DockPanel.Dock="Top" Padding="12,8"
					        Background="#252526" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
						<StackPanel Orientation="Horizontal" Spacing="6">
							<Button Classes="btn-link" Padding="0" Cursor="Hand"
							        Click="OnTogglePlanOverview"
							        ToolTip.Tip="展开/折叠计划步骤">
								<TextBlock Text="{Binding Detail.PlanToggleIcon}"
								           Foreground="#858585" FontSize="11" />
							</Button>
							<TextBlock Text="执行计划"
							           Foreground="#cccccc" FontSize="12" FontWeight="SemiBold" />
							<TextBlock Foreground="#858585" FontSize="11" VerticalAlignment="Center"
							           x:CompileBindings="False">
								<TextBlock.Text>
									<MultiBinding StringFormat="({0})">
										<Binding Path="Detail.PlanSteps.Count" />
									</MultiBinding>
								</TextBlock.Text>
							</TextBlock>
						</StackPanel>
					</Border>

					<!-- 步骤列表 -->
					<ScrollViewer x:Name="PlanScrollViewer"
					              VerticalScrollBarVisibility="Auto"
					              IsVisible="{Binding Detail.IsPlanOverviewExpanded}">
						<ItemsControl ItemsSource="{Binding Detail.PlanSteps}"
						              Margin="8,4">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<StackPanel Orientation="Vertical" Spacing="2" />
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<ItemsControl.ItemTemplate>
								<DataTemplate x:DataType="vm:PlanStepOverviewVm">
									<Border Classes="step-item">
										<Grid ColumnDefinitions="Auto,*,Auto">
											<!-- 序号 + 状态图标 -->
											<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6"
											            VerticalAlignment="Center">
												<TextBlock Text="{Binding StatusIcon}"
												           FontSize="12" VerticalAlignment="Center" />
												<TextBlock Foreground="#858585" FontSize="11"
												           VerticalAlignment="Center">
													<TextBlock.Text>
														<MultiBinding StringFormat="#{0}">
															<Binding Path="Sequence" />
														</MultiBinding>
													</TextBlock.Text>
												</TextBlock>
											</StackPanel>
											<!-- 标题 -->
											<TextBlock Grid.Column="1"
											           Text="{Binding Title}"
											           Foreground="#cccccc" FontSize="12"
											           TextTrimming="CharacterEllipsis"
											           Margin="8,0"
											           VerticalAlignment="Center" />
											<!-- 模式标签 -->
											<TextBlock Grid.Column="2"
											           Text="{Binding ModeText}"
											           Foreground="#6a6a6a" FontSize="10"
											           VerticalAlignment="Center" />
										</Grid>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</ScrollViewer>
				</DockPanel>
			</Border>

			<!-- 面板分隔线 -->
			<Border Grid.Column="1" Classes="panel-separator" />

			<!-- ── 右面板: 时间线事件流 ── -->
			<DockPanel Grid.Column="2" Background="#1e1e1e">
				<!-- 面板标题 -->
				<Border DockPanel.Dock="Top" Padding="12,8"
				        Background="#252526" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
					<TextBlock Text="执行时间线"
					           Foreground="#cccccc" FontSize="12" FontWeight="SemiBold" />
				</Border>

				<!-- 时间线内容 -->
				<ScrollViewer x:Name="TimelineScrollViewer"
				              VerticalScrollBarVisibility="Auto"
				              Padding="12,8">
					<StackPanel Spacing="0">
						<!-- 时间线事件列表 -->
						<ItemsControl ItemsSource="{Binding Detail.TimelineEvents}">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<StackPanel Orientation="Vertical" />
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<ItemsControl.ItemTemplate>
								<DataTemplate x:DataType="vm:TimelineEventVm">
									<Grid ColumnDefinitions="58,20,*" MinHeight="32" Margin="0,0,0,2">
										<!-- 左: 时间 -->
										<TextBlock Grid.Column="0" Text="{Binding TimeText}"
										           Foreground="#858585" FontSize="11"
										           HorizontalAlignment="Right" Margin="0,3,6,0" />
										<!-- 中: 竖线 + 圆点 -->
										<Panel Grid.Column="1">
											<Border Width="2" Background="#3c3c3c"
											        HorizontalAlignment="Center"
											        VerticalAlignment="Stretch" />
											<Ellipse Width="{Binding NodeSize}" Height="{Binding NodeSize}"
											         HorizontalAlignment="Center"
											         VerticalAlignment="Top"
											         Margin="0,5,0,0"
											         x:CompileBindings="False">
												<Ellipse.Fill>
													<SolidColorBrush Color="{Binding ActualNodeColor}" />
												</Ellipse.Fill>
											</Ellipse>
										</Panel>
										<!-- 右: 内容 -->
										<StackPanel Grid.Column="2" Spacing="2" Margin="8,0,0,4">
											<!-- 标题行 -->
											<TextBlock Text="{Binding Title}"
											           FontSize="13"
											           FontWeight="{Binding TitleFontWeight}"
											           TextWrapping="Wrap"
											           x:CompileBindings="False">
												<TextBlock.Foreground>
													<SolidColorBrush Color="{Binding TitleColor}" />
												</TextBlock.Foreground>
											</TextBlock>
											<!-- 详情 -->
											<TextBlock Text="{Binding Detail}"
											           Foreground="#9e9e9e" FontSize="12"
											           TextWrapping="Wrap"
											           MaxLines="8"
											           IsVisible="{Binding HasDetail}" />
											<!-- 进度条 -->
											<ProgressBar Value="{Binding ProgressPercent}"
											             Maximum="100" MinHeight="4"
											             Foreground="#007acc"
											             Background="#3c3c3c"
											             IsVisible="{Binding HasProgress}"
											             Margin="0,2,20,0" />
											<!-- 内嵌卡片 -->
											<Border IsVisible="{Binding HasCard}"
											        Background="#252526"
											        BorderBrush="#3c3c3c" BorderThickness="1"
											        CornerRadius="6" Padding="12,8"
											        Margin="0,4,16,4"
											        x:CompileBindings="False">
												<StackPanel Spacing="6">
													<TextBlock Text="{Binding Card.Title}"
													           Foreground="#cccccc" FontSize="12"
													           FontWeight="SemiBold" />
													<!-- 卡片内容行 -->
													<ItemsControl ItemsSource="{Binding Card.ContentLines}">
														<ItemsControl.ItemTemplate>
															<DataTemplate>
																<TextBlock Text="{Binding}"
																           Foreground="#9e9e9e" FontSize="11"
																           TextWrapping="Wrap"
																           Margin="0,1" />
															</DataTemplate>
														</ItemsControl.ItemTemplate>
													</ItemsControl>
													<!-- 卡片操作按钮 -->
													<ItemsControl ItemsSource="{Binding Card.Actions}">
														<ItemsControl.ItemsPanel>
															<ItemsPanelTemplate>
																<StackPanel Orientation="Horizontal" Spacing="6" />
															</ItemsPanelTemplate>
														</ItemsControl.ItemsPanel>
														<ItemsControl.ItemTemplate>
															<DataTemplate x:DataType="vm:TimelineCardActionVm">
																<Button Content="{Binding Label}"
																        Tag="{Binding ActionId}"
																        Click="OnCardActionClick"
																        Padding="10,5"
																        CornerRadius="3"
																        FontSize="12"
																        Cursor="Hand"
																        BorderThickness="0"
																        Background="#3a3d41"
																        Foreground="#cccccc" />
															</DataTemplate>
														</ItemsControl.ItemTemplate>
													</ItemsControl>
												</StackPanel>
											</Border>
										</StackPanel>
									</Grid>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>

						<!-- 最终报告 -->
						<StackPanel Spacing="6" Margin="78,8,0,0"
						            IsVisible="{Binding Detail.IsCompleted}">
							<TextBlock Text="最终报告" Foreground="#73c991" FontSize="13" FontWeight="SemiBold" />
							<Border Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1"
							        CornerRadius="4" Padding="14" Margin="0,0,16,0">
								<controls:MarkdownRenderer Markdown="{Binding Detail.FinalReport}" />
							</Border>
						</StackPanel>

						<!-- 错误信息 -->
						<StackPanel Spacing="6" Margin="78,8,0,0"
						            IsVisible="{Binding Detail.IsFailed}">
							<TextBlock Text="失败详情" Foreground="#f48771" FontSize="13" FontWeight="SemiBold" />
							<Border Background="#3a1f1f" BorderBrush="#6e2828" BorderThickness="1"
							        CornerRadius="4" Padding="14" Margin="0,0,16,0">
								<SelectableTextBlock Text="{Binding Detail.ErrorMessage}"
								                     Foreground="#f48771" FontSize="13" TextWrapping="Wrap" />
							</Border>
						</StackPanel>

						<!-- 取消提示 -->
						<TextBlock Margin="78,8,0,0"
						           Text="该任务已被取消"
						           Foreground="#858585" FontSize="13" FontStyle="Italic"
						           IsVisible="{Binding Detail.IsCancelled}" />
					</StackPanel>
				</ScrollViewer>
			</DockPanel>
		</Grid>

		<!-- ════════════════════════════════════════════════════════════════
		     Row 2: 底部输入工具栏
		     ════════════════════════════════════════════════════════════════ -->
		<Border Grid.Row="2" x:Name="InputArea"
		        Background="#1e1e1e"
		        BorderBrush="#3c3c3c" BorderThickness="0,1,0,0"
		        Padding="4,4"
		        x:CompileBindings="False">
			<StackPanel Spacing="4">
				<!-- 校验错误提示 -->
				<TextBlock Text="{Binding ValidationError}"
				           Foreground="#f48771" FontSize="11"
				           IsVisible="{Binding ValidationError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
				           Margin="4,0,0,4" />

				<!-- 工具栏选择器 -->
				<StackPanel Orientation="Horizontal" Spacing="8" Margin="4,0">
					<!-- 附件按钮 -->
					<Button x:Name="AttachButton" Classes="titlebar-btn" Padding="6,3"
					        ToolTip.Tip="添加附件" Click="OnAttachClick"
					        IsEnabled="{Binding IsIdle}">
						<StackPanel Orientation="Horizontal" Spacing="4">
							<Image Source="/Assets/attachment.png" Width="14" Height="14" />
							<TextBlock Text="附件" Foreground="#a0a0a0" FontSize="12" />
						</StackPanel>
					</Button>

					<!-- 智能体选择器 -->
					<Button x:Name="AgentSelectorBtn" Classes="titlebar-btn" Padding="6,3"
					        Click="OnAgentSelectorClick"
					        IsEnabled="{Binding IsIdle}">
						<StackPanel Orientation="Horizontal" Spacing="4">
							<Image Source="/Assets/agent.png" Width="14" Height="14" />
							<TextBlock x:Name="ToolbarAgentLabel" Text="{Binding SelectedManagerName}"
							           Foreground="#a0a0a0" FontSize="12" />
							<TextBlock Text="▲" Foreground="#6a6a6a" FontSize="9" VerticalAlignment="Center" />
						</StackPanel>
					</Button>

					<!-- 厂商选择器 -->
					<Button x:Name="ProviderSelectorBtn" Classes="titlebar-btn" Padding="6,3"
					        Click="OnProviderSelectorClick"
					        IsEnabled="{Binding IsIdle}">
						<StackPanel Orientation="Horizontal" Spacing="4">
							<Image Source="/Assets/provider.png" Width="14" Height="14" />
							<TextBlock x:Name="ToolbarProviderLabel" Text="{Binding SelectedProviderName}"
							           Foreground="#a0a0a0" FontSize="12" />
							<TextBlock Text="▲" Foreground="#6a6a6a" FontSize="9" VerticalAlignment="Center" />
						</StackPanel>
					</Button>

					<!-- 模型选择器 -->
					<Button x:Name="ModelSelectorBtn" Classes="titlebar-btn" Padding="6,3"
					        Click="OnModelSelectorClick"
					        IsEnabled="{Binding IsIdle}">
						<StackPanel Orientation="Horizontal" Spacing="4">
							<Image Source="/Assets/model.png" Width="14" Height="14" />
							<TextBlock x:Name="ToolbarModelLabel" Text="{Binding SelectedModelName}"
							           Foreground="#a0a0a0" FontSize="12" />
							<TextBlock Text="▲" Foreground="#6a6a6a" FontSize="9" VerticalAlignment="Center" />
						</StackPanel>
					</Button>

					<!-- 工具屏蔽按钮 -->
					<Button x:Name="ToolButton" Classes="titlebar-btn" Padding="6,3"
					        ToolTip.Tip="高风险工具屏蔽（默认全部允许）"
					        Click="OnToolPopupOpenClick"
					        IsEnabled="{Binding IsIdle}">
						<StackPanel Orientation="Horizontal" Spacing="4">
							<Image Source="/Assets/tools.png" Width="14" Height="14" />
							<TextBlock Text="工具" Foreground="#a0a0a0" FontSize="12" />
							<TextBlock Text="▲" Foreground="#6a6a6a" FontSize="9" VerticalAlignment="Center" />
						</StackPanel>
					</Button>
				</StackPanel>
			</StackPanel>
		</Border>

		<!-- ════════════════════════════════════════════════════════════════
		     Popup 集
		     ════════════════════════════════════════════════════════════════ -->

		<!-- 智能体 Popup -->
		<Popup x:Name="AgentSelectorPopup" Placement="TopEdgeAlignedLeft"
		       PlacementTarget="{Binding #AgentSelectorBtn}"
		       IsLightDismissEnabled="True">
			<Border Background="#181818" CornerRadius="6"
			        BorderBrush="#3c3c3c" BorderThickness="1"
			        Padding="4" MinWidth="200" MaxHeight="300">
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<ItemsControl x:Name="AgentSelectorList">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<StackPanel Spacing="2" />
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
					</ItemsControl>
				</ScrollViewer>
			</Border>
		</Popup>

		<!-- 厂商 Popup -->
		<Popup x:Name="ProviderPopup" Placement="TopEdgeAlignedLeft"
		       PlacementTarget="{Binding #ProviderSelectorBtn}"
		       IsLightDismissEnabled="True">
			<Border Background="#181818" CornerRadius="6"
			        BorderBrush="#3c3c3c" BorderThickness="1"
			        Padding="4" MinWidth="200" MaxHeight="300">
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<ItemsControl x:Name="ProviderList">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<StackPanel Spacing="2" />
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
					</ItemsControl>
				</ScrollViewer>
			</Border>
		</Popup>

		<!-- 模型 Popup -->
		<Popup x:Name="ModelPopup" Placement="TopEdgeAlignedLeft"
		       PlacementTarget="{Binding #ModelSelectorBtn}"
		       IsLightDismissEnabled="True">
			<Border Background="#181818" CornerRadius="6"
			        BorderBrush="#3c3c3c" BorderThickness="1"
			        Padding="4" MinWidth="220" MaxHeight="360">
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<ItemsControl x:Name="ModelList">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<StackPanel Spacing="2" />
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
					</ItemsControl>
				</ScrollViewer>
			</Border>
		</Popup>

		<!-- 工具屏蔽 Popup -->
		<Popup x:Name="ToolPopup" Placement="TopEdgeAlignedLeft"
		       PlacementTarget="{Binding #ToolButton}"
		       IsLightDismissEnabled="True">
			<Border Background="#181818" CornerRadius="6"
			        BorderBrush="#3c3c3c" BorderThickness="1"
			        Padding="12" MinWidth="320">
				<StackPanel Spacing="8">
					<TextBlock Text="高风险工具屏蔽"
					           Foreground="#cccccc" FontSize="12" FontWeight="SemiBold" />
					<TextBlock Text="勾选后，本任务执行时屏蔽所选工具（默认全部允许）。"
					           Foreground="#858585" FontSize="11" TextWrapping="Wrap" />
					<ItemsControl ItemsSource="{Binding HighRiskTools}"
					              x:CompileBindings="False">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<CheckBox Content="{Binding DisplayName}"
								          IsChecked="{Binding IsBlocked, Mode=TwoWay}"
								          ToolTip.Tip="{Binding Description}"
								          Foreground="#cccccc" FontSize="12"
								          Margin="0,2" />
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</StackPanel>
			</Border>
		</Popup>
	</Grid>
</UserControl>
