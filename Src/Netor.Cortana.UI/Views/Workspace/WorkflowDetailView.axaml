<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Netor.Cortana.UI.ViewModels.Workspace"
             xmlns:controls="using:Netor.Cortana.UI.Controls"
             x:Class="Netor.Cortana.UI.Views.Workspace.WorkflowDetailView"
             x:DataType="vm:WorkspaceTabVm"
             x:CompileBindings="True"
             Background="#1e1e1e">

	<!--
	  ╔══════════════════════════════════════════════════════════════╗
	  ║  重构版 2026-05-26 v2                                       ║
	  ║  设计原则：纯对话流 + 时间线进度面板                          ║
	  ║  文档 08 §2.2 对话模式 / §2.3 执行模式（竖线时间线）          ║
	  ║  布局：Grid 两行                                             ║
	  ║  Row 0 (*):    对话流（空状态 / Feed 列表）                  ║
	  ║  Row 1 (Auto): 输入区（InputAreaView 共享控件）              ║
	  ╚══════════════════════════════════════════════════════════════╝
	-->
	<Grid x:Name="DetailRoot" RowDefinitions="*,Auto">

		<!-- ═══════════════════════════════════════════════════════════
		     Row 0：对话流区域
		     ═══════════════════════════════════════════════════════════ -->
		<Panel Grid.Row="0">

			<!-- 无任务选中：空状态提示 -->
			<controls:EmptyState x:Name="EmptyHint"
			                     IsVisible="{Binding Detail.TaskId, Converter={x:Static StringConverters.IsNullOrEmpty}}"
			                     IconText="&#x1F4CB;"
			                     Title="选择左侧任务查看详情"
			                     Description="左侧任务列表为空时，在下方输入框中输入任务描述并发送即可创建新任务。" />

			<!-- 有任务：统一对话流 -->
			<ScrollViewer x:Name="FeedScrollViewer"
			              IsVisible="{Binding Detail.TaskId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
			              VerticalScrollBarVisibility="Auto"
			              HorizontalScrollBarVisibility="Disabled"
			              HorizontalContentAlignment="Stretch">

				<ItemsControl x:Name="FeedList"
				              ItemsSource="{Binding Detail.FeedItems}"
				              HorizontalAlignment="Stretch"
				              Margin="16,10,16,60"
				              x:CompileBindings="False">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<StackPanel Orientation="Vertical" HorizontalAlignment="Stretch" />
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Grid Margin="0,0,0,2" HorizontalAlignment="Stretch">

								<!-- ── 用户消息：半透明边框气泡 ── -->
								<Border IsVisible="{Binding IsUserMessage}"
								        Background="#186a9fd8"
								        BorderBrush="#406a9fd8" BorderThickness="1"
								        CornerRadius="3" Padding="10,6"
								        Margin="8,4,8,4">
									<SelectableTextBlock Text="{Binding Content}"
									                     Foreground="#d4d4d4" FontSize="13"
									                     TextWrapping="Wrap" />
								</Border>

								<!-- ── AI 回复：纯文本 + 流式光标 ── -->
								<StackPanel IsVisible="{Binding IsAiMessage}"
								            Spacing="3" Margin="8,4,8,4">
									<SelectableTextBlock Text="{Binding Content}"
									                     Foreground="#cccccc"
									                     FontSize="13" TextWrapping="Wrap"
									                     IsVisible="{Binding HasContent}" />
									<TextBlock Text="&#x258C;" Foreground="#73c991" FontSize="13"
									           IsVisible="{Binding IsStreaming}" />
								</StackPanel>

								<!-- ── 执行结果：摘要 + 产出文件 ── -->
								<StackPanel IsVisible="{Binding IsResult}"
								            Spacing="6" Margin="8,4,8,4">
									<SelectableTextBlock Text="{Binding Content}"
									                     Foreground="#e0c074"
									                     FontSize="13" TextWrapping="Wrap"
									                     IsVisible="{Binding HasContent}" />
									<TextBlock Text="{Binding ResultSummary}"
									           Foreground="#cccccc" FontSize="12"
									           TextWrapping="Wrap"
									           IsVisible="{Binding ResultSummary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
									<ItemsControl ItemsSource="{Binding ResultFiles}"
									              IsVisible="{Binding HasResultFiles}"
									              x:CompileBindings="False">
										<ItemsControl.ItemsPanel>
											<ItemsPanelTemplate>
												<WrapPanel Orientation="Horizontal" />
											</ItemsPanelTemplate>
										</ItemsControl.ItemsPanel>
										<ItemsControl.ItemTemplate>
											<DataTemplate>
												<Border Classes="attachment-tag">
													<StackPanel Orientation="Horizontal" Spacing="4">
														<TextBlock Text="{Binding IconText}" FontSize="12" />
														<TextBlock Text="{Binding DisplayName}"
														           FontSize="12" Foreground="#cccccc"
														           ToolTip.Tip="{Binding FullPathTooltip}"
														           MaxWidth="200"
														           TextTrimming="CharacterEllipsis" />
														<TextBlock Text="{Binding SizeText}"
														           FontSize="11" Foreground="#858585"
														           IsVisible="{Binding SizeText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
													</StackPanel>
												</Border>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
									</ItemsControl>
								</StackPanel>

								<!-- ══════════════════════════════════════════════════════
								     进度消息：竖线时间线 + 圆点 + 层级文本
								     文档 08 §2.3 — 时间轴 + 圆点节点 + 子过程详情行

								     结构（从左到右）：
								     [竖线区 24px] [圆点+文本区]

								     竖线区包含一条 1px 竖线从上到下贯穿（最后一条除外）
								     圆点区在竖线上方叠加圆点（阶段=10px / 步骤=8px / 计划=8px）
								     文本区根据 ProgressKind 切换字号和粗细
								     ══════════════════════════════════════════════════════ -->
								<Grid IsVisible="{Binding IsProgress}"
								      ColumnDefinitions="24,*"
								      Margin="8,0,8,0"
								      MinHeight="22">

									<!-- 左列：竖线 + 圆点 -->
									<Panel Grid.Column="0"
									       HorizontalAlignment="Center"
									       VerticalAlignment="Stretch">

										<!-- 向下延伸的竖线（非最后一条时显示） -->
										<Border Width="1.5"
										        Background="#333333"
										        HorizontalAlignment="Center"
										        VerticalAlignment="Stretch"
										        IsVisible="{Binding !IsLastProgress}" />

										<!-- 上半段竖线（最后一条时只画上半段到圆点中心） -->
										<Border Width="1.5"
										        Background="#333333"
										        HorizontalAlignment="Center"
										        VerticalAlignment="Top"
										        Height="11"
										        IsVisible="{Binding IsLastProgress}" />

										<!-- 阶段级圆点（大，10x10） -->
										<Border IsVisible="{Binding IsPhaseNode}"
										        Width="10" Height="10"
										        CornerRadius="5"
										        Background="{Binding DotColor}"
										        HorizontalAlignment="Center"
										        VerticalAlignment="Top"
										        Margin="0,6,0,0" />

										<!-- 步骤级圆点（中，8x8） -->
										<Border IsVisible="{Binding IsStepNode}"
										        Width="8" Height="8"
										        CornerRadius="4"
										        Background="{Binding DotColor}"
										        HorizontalAlignment="Center"
										        VerticalAlignment="Top"
										        Margin="0,7,0,0" />

										<!-- 计划/验证/生命周期圆点（中，8x8） -->
										<Border IsVisible="{Binding IsOtherTimelineNode}"
										        Width="8" Height="8"
										        CornerRadius="4"
										        Background="{Binding DotColor}"
										        HorizontalAlignment="Center"
										        VerticalAlignment="Top"
										        Margin="0,7,0,0" />

										<!-- 详情行：无圆点，只有竖线穿过 -->
									</Panel>

									<!-- 右列：文本内容 -->
									<StackPanel Grid.Column="1"
									            Spacing="1"
									            Margin="6,3,0,3"
									            VerticalAlignment="Top">

										<!-- 阶段标题：14px 粗体 -->
										<TextBlock IsVisible="{Binding IsPhaseNode}"
										           Text="{Binding TimelineTitle}"
										           Foreground="{Binding DotColor}"
										           FontSize="14"
										           FontWeight="SemiBold"
										           TextWrapping="Wrap" />

										<!-- 步骤标题：13px 半粗体 -->
										<TextBlock IsVisible="{Binding IsStepNode}"
										           Text="{Binding TimelineTitle}"
										           Foreground="{Binding DotColor}"
										           FontSize="13"
										           FontWeight="Medium"
										           TextWrapping="Wrap" />

										<!-- 计划消息：13px 普通 -->
										<TextBlock IsVisible="{Binding IsPlanNode}"
										           Text="{Binding TimelineTitle}"
										           Foreground="{Binding DotColor}"
										           FontSize="13"
										           TextWrapping="Wrap" />

										<!-- 验证消息：13px 普通 -->
										<TextBlock IsVisible="{Binding IsValidationNode}"
										           Text="{Binding TimelineTitle}"
										           Foreground="{Binding DotColor}"
										           FontSize="13"
										           TextWrapping="Wrap" />

										<!-- 生命周期消息：13px 粗体 -->
										<TextBlock IsVisible="{Binding IsLifecycleNode}"
										           Text="{Binding TimelineTitle}"
										           Foreground="{Binding DotColor}"
										           FontSize="13"
										           FontWeight="SemiBold"
										           TextWrapping="Wrap" />

										<!-- 详情行（子过程）：11px 灰色 -->
										<TextBlock IsVisible="{Binding IsDetailLine}"
										           Text="{Binding Content}"
										           Foreground="#858585"
										           FontSize="11"
										           TextWrapping="Wrap"
										           Opacity="0.85" />

										<!-- 副文本（步骤完成时的结果摘要等） -->
										<TextBlock Text="{Binding TimelineSubText}"
										           Foreground="#858585"
										           FontSize="11"
										           TextWrapping="Wrap"
										           Opacity="0.85"
										           Margin="0,1,0,0"
										           IsVisible="{Binding TimelineSubText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
									</StackPanel>
								</Grid>

								<!-- ── 系统消息：灰色斜体 ── -->
								<TextBlock IsVisible="{Binding IsSystem}"
								           Text="{Binding Content}"
								           Foreground="#858585"
								           FontSize="12"
								           FontStyle="Italic"
								           TextWrapping="Wrap"
								           Margin="8,2,8,2" />

								<!-- ── 工具授权请求：内联在对话流中 ── -->
								<Border IsVisible="{Binding IsToolAuth}"
								        Background="#2a2010" BorderBrush="#e0c074" BorderThickness="1"
								        CornerRadius="4" Padding="12,10"
								        Margin="8,4,8,4">
									<StackPanel Spacing="8">
										<TextBlock Text="{Binding Content}"
										           Foreground="#d4d4d4" FontSize="13"
										           TextWrapping="Wrap" />
										<Border Background="#1e1e1e" CornerRadius="3" Padding="8,6"
										        IsVisible="{Binding ParametersSummary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
											<SelectableTextBlock Text="{Binding ParametersSummary}"
											                     Foreground="#9e9e9e" FontSize="12"
											                     TextWrapping="Wrap" />
										</Border>
										<StackPanel Orientation="Horizontal" Spacing="6">
											<Button Classes="approval-btn-primary"
											        Content="&#x2713; 确认执行"
											        Tag="{Binding AuthRequestId}"
											        Click="OnToolAuthConfirmClick" />
											<Button Classes="approval-btn-secondary"
											        Content="&#x2713;&#x2713; 本任务全部授权"
											        IsVisible="{Binding ShowGrantAllOption}"
											        Tag="{Binding}"
											        Click="OnToolAuthGrantAllClick"
											        ToolTip.Tip="本任务内该工具后续调用不再询问" />
											<Button Classes="approval-btn-danger"
											        Content="&#x2715; 拒绝本次调用"
											        Tag="{Binding AuthRequestId}"
											        Click="OnToolAuthDenyClick"
											        ToolTip.Tip="拒绝本次调用，AI 自行寻找替代方案" />
										</StackPanel>
									</StackPanel>
								</Border>

							</Grid>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>

			</ScrollViewer>
		</Panel>

		<!-- ═══════════════════════════════════════════════════════════
		     Row 1：输入区（共享 InputAreaView）
		     ═══════════════════════════════════════════════════════════ -->
		<Border Grid.Row="1" x:Name="InputAreaBorder"
		        Background="#1e1e1e"
		        BorderBrush="#252526" BorderThickness="0,1,0,0"
		        Padding="6,6,6,6"
		        x:CompileBindings="False">
			<!-- 共享输入区（Workflow 模式：橙色走马灯，含子模式+厂商/模型+工具按钮） -->
			<controls:InputAreaView x:Name="WorkflowInputArea"
			                        InputMode="Workflow"
			                        MarqueeColor="#ff9c40" />
		</Border>

	</Grid>
</UserControl>
