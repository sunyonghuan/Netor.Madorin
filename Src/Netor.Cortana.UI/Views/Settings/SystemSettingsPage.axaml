<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Netor.Cortana.UI.Views.Settings.SystemSettingsPage"
             x:CompileBindings="True">

    <Panel>
        <DockPanel>
            <!-- 顶部标题栏 -->
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="16,12,16,8">
                <TextBlock Text="系统设置" FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Classes="btn-secondary" Content="恢复默认" Click="OnResetClick" />
                    <Button Classes="btn-primary" Content="保存设置" Click="OnSaveClick" />
                </StackPanel>
            </Grid>

            <!-- 设置项容器 -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="SettingsContainer" Spacing="12" Margin="8,0" />
            </ScrollViewer>
        </DockPanel>

        <!-- 原生 Avalonia Toast -->
        <Border x:Name="ToastBorder"
                IsVisible="False"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,52,0,0"
                Padding="16,10"
                CornerRadius="8"
                Background="{StaticResource Surface1Brush}"
                BorderBrush="{StaticResource BlueBrush}"
                BorderThickness="1"
                BoxShadow="0 6 18 0 #66000000">
            <TextBlock x:Name="ToastText"
                       Foreground="{StaticResource TextBrush}"
                       FontSize="13"
                       TextWrapping="Wrap"
                       MaxWidth="520" />
        </Border>
    </Panel>

</UserControl>
