<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Netor.Cortana.UI.Controls"
        xmlns:workspace="using:Netor.Cortana.UI.Views.Workspace"
        x:Class="Netor.Cortana.UI.Views.MainWindow"
        x:CompileBindings="True"
        Title="小娜宝贝"
        Width="560" Height="980"
        MinWidth="400" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e"
        ExtendClientAreaToDecorationsHint="True">

	<!-- 配色资源已迁移至 Styles/ThemeResources.axaml，全局可用 -->

	<Window.Styles>
		<!-- ── 输入框样式 ── -->
		<Style Selector="TextBox.chat-input">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="Foreground" Value="#cccccc" />
			<Setter Property="CaretBrush" Value="#007acc" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="FontSize" Value="13" />
			<Setter Property="Padding" Value="0" />
		</Style>
		<Style Selector="TextBox.chat-input:focus /template/ Border">
			<Setter Property="BorderThickness" Value="0" />
		</Style>
		<Style Selector="TextBox.chat-input:pointerover /template/ Border">
			<Setter Property="Background" Value="Transparent" />
		</Style>
		<Style Selector="TextBox.chat-input:focus /template/ Border">
			<Setter Property="Background" Value="Transparent" />
		</Style>

		<!-- ── 工具栏按钮 ── -->
		<Style Selector="Button.titlebar-btn">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="Foreground" Value="#858585" />
			<Setter Property="FontSize" Value="14" />
			<Setter Property="Padding" Value="8,4" />
			<Setter Property="CornerRadius" Value="4" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="MinWidth" Value="26" />
			<Setter Property="MinHeight" Value="24" />
			<Setter Property="BorderThickness" Value="0" />
		</Style>
		<Style Selector="Button.titlebar-btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="#252526" />
			<Setter Property="Foreground" Value="#cccccc" />
		</Style>

		<!-- 阶段 6 Phase 3：StopButton 专用 hover 警示色（与 Workspace CancelButton 语义统一）。
		     决策 6-3-D：保留 titlebar-btn 的 class 复用，仅叠加 titlebar-btn-warn 让 StopButton hover 变红，
		     避免改 titlebar-btn 全局样式影响其他历史/设置/新建会话等按钮。
		     详见 docs/未来版本策划/多智能体编排模式策划/04-实施阶段.md §阶段 6 #3。 -->
		<Style Selector="Button.titlebar-btn-warn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="#3a1f1f" />
			<Setter Property="Foreground" Value="#d85050" />
		</Style>

		<!-- ── 拖拽分隔条 ── -->
		<Style Selector="GridSplitter">
			<Setter Property="Background" Value="Transparent" />
		</Style>
		<Style Selector="GridSplitter:pointerover">
			<Setter Property="Background" Value="#3c3c3c" />
		</Style>

		<!-- ── 选择器项样式 ── -->
		<Style Selector="Button.selector-item">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="Foreground" Value="#cccccc" />
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="HorizontalContentAlignment" Value="Left" />
			<Setter Property="Padding" Value="10,6" />
			<Setter Property="CornerRadius" Value="4" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="BorderThickness" Value="0" />
		</Style>
		<Style Selector="Button.selector-item:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#252526" />
		</Style>
		<Style Selector="Button.selector-item-active">
			<Setter Property="Background" Value="#252526" />
			<Setter Property="Foreground" Value="#007acc" />
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="HorizontalContentAlignment" Value="Left" />
			<Setter Property="Padding" Value="10,6" />
			<Setter Property="CornerRadius" Value="4" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="BorderThickness" Value="0" />
		</Style>
		<Style Selector="Button.selector-item-active /template/ ContentPresenter">
			<Setter Property="Background" Value="#252526" />
		</Style>

		<!-- ── 顶部 Tab 切换按钮（Chat / Workspace） ── -->
		<Style Selector="Button.tab-btn">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="Foreground" Value="#858585" />
			<Setter Property="FontSize" Value="13" />
			<Setter Property="FontWeight" Value="SemiBold" />
			<Setter Property="Padding" Value="12,4" />
			<Setter Property="CornerRadius" Value="4" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="BorderThickness" Value="0" />
		</Style>
		<Style Selector="Button.tab-btn:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#252526" />
			<Setter Property="Foreground" Value="#cccccc" />
		</Style>
		<Style Selector="Button.tab-btn-active">
			<Setter Property="Background" Value="#252526" />
			<Setter Property="Foreground" Value="#007acc" />
		</Style>
		<Style Selector="Button.tab-btn-active /template/ ContentPresenter">
			<Setter Property="Background" Value="#252526" />
			<Setter Property="Foreground" Value="#007acc" />
		</Style>

		<!-- ── 附件标签样式 ── -->
		<Style Selector="Border.attachment-tag">
			<Setter Property="Background" Value="#252526" />
			<Setter Property="CornerRadius" Value="4" />
			<Setter Property="Padding" Value="8,4" />
			<Setter Property="Margin" Value="0,0,6,4" />
		</Style>
	</Window.Styles>

	<Panel Background="#1e1e1e">

		<!-- ══════ 主布局 ══════ -->
		<Grid x:Name="WorkspaceGrid" Margin="0,36,0,0">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="0" MinWidth="0" MaxWidth="600" />
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" MinWidth="200" />
			</Grid.ColumnDefinitions>

			<!-- Col 0: 左侧面板（界面重设计 C3：替代原 WorkspaceExplorer 直挂载，引入底部 Tab 切换）。
			     原 WorkspaceExplorer 内部的 36px 标题栏占位 hack 已剥离（详见 04-实施阶段.md §3.4），
			     由 LeftPanel.axaml 的 Grid.Row[0]=36px 显式占位 + 本节点保留 Margin="0,-36,0,0" 上移贴顶。
			     详见 Docs/未来版本策划/界面重设计/04-实施阶段.md §3.5 + 01-布局规格.md §3。 -->
			<Border Grid.Column="0" Margin="0,-36,0,0"
			        BorderBrush="#3c3c3c" BorderThickness="0,0,1,0"
			        Background="#1e1e1e">
				<controls:LeftPanel x:Name="LeftPanelHost" />
			</Border>

			<!-- Col 1: 拖拽分隔条 -->
			<GridSplitter x:Name="WorkspaceSplitter" Grid.Column="1"
			              Width="4" IsVisible="False" />

			<!-- Col 2: 主内容区 -->
			<DockPanel Grid.Column="2">

				<!-- ── 顶部标题栏 (36px) ── -->
				<Border DockPanel.Dock="Top" Height="36" Background="#1e1e1e">
					<Grid ColumnDefinitions="Auto,*,Auto" Margin="10,0">
						<!-- 左：工作台抽屉开关 -->
						<Button Grid.Column="0" Classes="titlebar-btn"
								ToolTip.Tip="工作台" Click="OnWorkspaceToggleClick">
							<Image Source="avares://Cortana/Assets/list.png" Width="14" Height="14" />
						</Button>
						<!-- 中：Tab 切换 + 会话标题 -->
						<!-- 界面重设计 C2：顶栏 tab 从 2 个 → 3 个（决策 UI-3 B1）。
						     原 WorkspaceTabButton (Tag=workspace, "工作台") → WorkflowTabButton (Tag=workflow, "工作流")，
						     新增 GroupChatTabButton (Tag=groupchat, "群聊")。
						     OnTabSwitchClick 兼容旧 "workspace" Tag（详见 WorkModeExtensions.FromPersistenceString）。
						     详见 Docs/未来版本策划/界面重设计/04-实施阶段.md §2.3。 -->
						<StackPanel Grid.Column="1" Orientation="Horizontal"
									HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
							<Button x:Name="ChatTabButton"
									Classes="tab-btn tab-btn-active"
									Tag="chat"
									Click="OnTabSwitchClick">
								<TextBlock Text="对话" />
							</Button>
							<Button x:Name="WorkflowTabButton"
									Classes="tab-btn"
									Tag="workflow"
									Click="OnTabSwitchClick">
								<TextBlock Text="工作流" />
							</Button>
							<Button x:Name="GroupChatTabButton"
									Classes="tab-btn"
									Tag="groupchat"
									Click="OnTabSwitchClick">
								<TextBlock Text="群聊" />
							</Button>
						</StackPanel>
						<!-- 右：操作按钮组 -->
						<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2"
									VerticalAlignment="Center">
							<Button Classes="titlebar-btn" ToolTip.Tip="新建会话" Click="OnNewSessionClick">
								<Image Source="avares://Cortana/Assets/add.png" Width="14" Height="14" />
							</Button>
							<Button Classes="titlebar-btn" ToolTip.Tip="清空页面消息" Click="OnClearMessagesClick">
								<Image Source="avares://Cortana/Assets/clear.png" Width="14" Height="14" />
							</Button>
							<Button Classes="titlebar-btn" ToolTip.Tip="设置" Click="OnSettingsClick">
								<Image Source="avares://Cortana/Assets/setting.png" Width="14" Height="14" />
							</Button>
						</StackPanel>
					</Grid>
				</Border>

				<!-- ── Tab 切换容器（Chat / Workspace 互斥显示） ── -->
				<Panel x:Name="ContentRoot">
				<DockPanel x:Name="ChatTabContent" IsVisible="True">

				<!-- ── 底部输入区 ── -->
				<Border DockPanel.Dock="Bottom" Background="#181818"
						BorderBrush="#252526" BorderThickness="0,1,0,0"
						Padding="6,6,6,0">
					<StackPanel Spacing="0,0,0,2">
						<!-- 阶段 5B Phase 3：Chat→Workflow 启发式建议 banner -->
						<!-- 默认隐藏，由 OnWorkflowSuggestion 事件订阅在 IsLikelyComplexTask 时显示 -->
						<Border x:Name="WorkflowSuggestionBanner"
								Background="#1f3a4d"
								BorderBrush="#0e7c8c"
								BorderThickness="1"
								CornerRadius="4"
								Padding="10,8"
								Margin="4,0,4,4"
								IsVisible="False">
							<Grid ColumnDefinitions="Auto,*,Auto,Auto">
								<TextBlock Grid.Column="0" Text="💡"
										   FontSize="14"
										   VerticalAlignment="Center"
										   Margin="0,0,8,0" />
								<StackPanel Grid.Column="1" Orientation="Vertical" Spacing="2"
											VerticalAlignment="Center">
									<TextBlock x:Name="WorkflowSuggestionReason"
											   Text="这看起来是一个复杂任务，是否切到工作模式？"
											   Foreground="#cccccc" FontSize="12"
											   TextWrapping="Wrap" />
									<TextBlock x:Name="WorkflowSuggestionInputPreview"
											   Foreground="#858585" FontSize="11"
											   FontStyle="Italic"
											   TextTrimming="CharacterEllipsis" />
								</StackPanel>
								<Button Grid.Column="2"
										Background="#0e639c" Foreground="#ffffff"
										Padding="10,4" CornerRadius="3"
										FontSize="12" Cursor="Hand"
										BorderThickness="0"
										Margin="8,0,4,0"
										Content="切到工作模式"
										Click="OnWorkflowSuggestionAcceptClick" />
								<Button Grid.Column="3"
										Background="Transparent" Foreground="#858585"
										Padding="6,4" CornerRadius="3"
										FontSize="12" Cursor="Hand"
										BorderThickness="0"
										Content="✕"
										ToolTip.Tip="忽略本次建议"
										Click="OnWorkflowSuggestionDismissClick" />
							</Grid>
						</Border>

						<!-- 附件预览区 -->
						<ItemsControl x:Name="AttachmentList" Margin="4,0">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<WrapPanel Orientation="Horizontal" />
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
						</ItemsControl>

						<!-- 输入框容器 -->
						<Panel x:Name="InputBorderHost" ClipToBounds="True">
							<Border x:Name="InputBorder" Background="#252526" CornerRadius="3"
									BorderBrush="#3c3c3c" BorderThickness="1"
									Padding="12"
									DragDrop.AllowDrop="True">
								<Grid ColumnDefinitions="*,Auto">
									<TextBox x:Name="InputBox" Grid.Column="0"
											 Classes="chat-input"
											 PlaceholderText="输入消息 (# 引用文件  @ 调用智能体  Enter 发送  Shift+Enter 换行) ..."
											 TextWrapping="Wrap"
											 AcceptsReturn="True"
											 MinHeight="80" MaxHeight="400" />
									<!-- 发送/停止 图标按钮 -->
									<Panel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Bottom">
										<!-- 发送按钮（空闲时显示） -->
										<Button x:Name="SendButton" Classes="titlebar-btn"
												ToolTip.Tip="发送" IsVisible="True" Click="OnSendClick">
											<Image Source="avares://Cortana/Assets/send.png" Width="14" Height="14" />
										</Button>
										<!-- 旋转加载按钮（发送中显示，点击可取消） -->
										<Button x:Name="StopButton" Classes="titlebar-btn titlebar-btn-warn"
												ToolTip.Tip="停止当前对话" IsVisible="False" Click="OnStopClick">
											<Image x:Name="SpinnerIcon"
												   Source="avares://Cortana/Assets/refresh.png"
												   Width="14" Height="14"
												   RenderTransformOrigin="50%,50%">
												<Image.RenderTransform>
													<RotateTransform Angle="0" />
												</Image.RenderTransform>
											</Image>
										</Button>
									</Panel>
								</Grid>
							</Border>

							<Border x:Name="InputMarqueeBorder" IsVisible="False" IsHitTestVisible="False"
									CornerRadius="3" ClipToBounds="True">
								<Canvas Height="0" Margin="0,0,0,-120"
										HorizontalAlignment="Stretch" VerticalAlignment="Top">
									<Rectangle x:Name="InputMarqueeTop" Width="120" Height="2" HorizontalAlignment="Left" VerticalAlignment="Top" RadiusX="1" RadiusY="1">
									<Rectangle.Fill>
										<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
											<GradientStop Color="#00007acc" Offset="0" />
											<GradientStop Color="#ff39d7ff" Offset="0.5" />
											<GradientStop Color="#00007acc" Offset="1" />
										</LinearGradientBrush>
									</Rectangle.Fill>
								</Rectangle>
									<Rectangle x:Name="InputMarqueeRight" Width="2" Height="120" HorizontalAlignment="Right" VerticalAlignment="Top" RadiusX="1" RadiusY="1">
									<Rectangle.Fill>
										<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
											<GradientStop Color="#00007acc" Offset="0" />
											<GradientStop Color="#ff39d7ff" Offset="0.5" />
											<GradientStop Color="#00007acc" Offset="1" />
										</LinearGradientBrush>
									</Rectangle.Fill>
								</Rectangle>
									<Rectangle x:Name="InputMarqueeBottom" Width="120" Height="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" RadiusX="1" RadiusY="1">
									<Rectangle.Fill>
										<LinearGradientBrush StartPoint="100%,0%" EndPoint="0%,0%">
											<GradientStop Color="#00007acc" Offset="0" />
											<GradientStop Color="#ff39d7ff" Offset="0.5" />
											<GradientStop Color="#00007acc" Offset="1" />
										</LinearGradientBrush>
									</Rectangle.Fill>
								</Rectangle>
									<Rectangle x:Name="InputMarqueeLeft" Width="2" Height="120" HorizontalAlignment="Left" VerticalAlignment="Bottom" RadiusX="1" RadiusY="1">
									<Rectangle.Fill>
										<LinearGradientBrush StartPoint="0%,100%" EndPoint="0%,0%">
											<GradientStop Color="#00007acc" Offset="0" />
											<GradientStop Color="#ff39d7ff" Offset="0.5" />
											<GradientStop Color="#00007acc" Offset="1" />
										</LinearGradientBrush>
									</Rectangle.Fill>
								</Rectangle>
								</Canvas>
							</Border>
						</Panel>

						<!-- # 文件补全弹出列表 -->
						<Popup x:Name="FilePopup" Placement="TopEdgeAlignedLeft"
							   PlacementTarget="{Binding #InputBorder}"
							   IsLightDismissEnabled="True">
							<Border Background="#181818" CornerRadius="6"
									BorderBrush="#3c3c3c" BorderThickness="1"
									Padding="4" MinWidth="300" MaxHeight="260">
								<ScrollViewer VerticalScrollBarVisibility="Auto">
									<ItemsControl x:Name="FileList">
										<ItemsControl.ItemsPanel>
											<ItemsPanelTemplate>
												<StackPanel Spacing="1" />
											</ItemsPanelTemplate>
										</ItemsControl.ItemsPanel>
									</ItemsControl>
								</ScrollViewer>
							</Border>
						</Popup>

						<!-- @ 智能体补全弹出列表 -->
						<Popup x:Name="AgentPopup" Placement="TopEdgeAlignedLeft"
							   PlacementTarget="{Binding #InputBorder}"
							   IsLightDismissEnabled="True">
							<Border Background="#181818" CornerRadius="6"
									BorderBrush="#3c3c3c" BorderThickness="1"
									Padding="4" MinWidth="300" MaxHeight="260">
								<ScrollViewer VerticalScrollBarVisibility="Auto">
									<ItemsControl x:Name="AgentList">
										<ItemsControl.ItemsPanel>
											<ItemsPanelTemplate>
												<StackPanel Spacing="1" />
											</ItemsPanelTemplate>
										</ItemsControl.ItemsPanel>
									</ItemsControl>
								</ScrollViewer>
							</Border>
						</Popup>

						<!-- 底部工具栏：附件 + 智能体/厂商/模型选择器 -->
						<StackPanel Orientation="Horizontal" Spacing="8" Margin="4,0">
							<!-- 附件按钮 -->
							<Button x:Name="AttachButton" Classes="titlebar-btn" Padding="6,3"
									ToolTip.Tip="添加附件" Click="OnAttachClick">
								<StackPanel Orientation="Horizontal" Spacing="4">
									<Image Source="/Assets/attachment.png" Width="14" Height="14" />
									<TextBlock Text="附件" Foreground="#a0a0a0" FontSize="12" />
								</StackPanel>
							</Button>
							<!-- 智能体选择器 -->
							<Button x:Name="AgentSelectorBtn" Classes="titlebar-btn" Padding="6,3"
									Click="OnAgentSelectorClick">
								<StackPanel Orientation="Horizontal" Spacing="4">
									<Image Source="/Assets/agent.png" Width="14" Height="14" />
									<TextBlock x:Name="ToolbarAgentLabel" Text="智能体"
											   Foreground="#a0a0a0" FontSize="12" />
									<TextBlock Text="▲" Foreground="#6a6a6a" FontSize="9"
											   VerticalAlignment="Center" />
								</StackPanel>
							</Button>
							<!-- 厂商选择器 -->
							<Button x:Name="ProviderSelectorBtn" Classes="titlebar-btn" Padding="6,3"
									Click="OnProviderSelectorClick">
								<StackPanel Orientation="Horizontal" Spacing="4">
									<Image Source="/Assets/provider.png" Width="14" Height="14" />
									<TextBlock x:Name="ToolbarProviderLabel" Text="厂商"
											   Foreground="#a0a0a0" FontSize="12" />
									<TextBlock Text="▲" Foreground="#6a6a6a" FontSize="9"
											   VerticalAlignment="Center" />
								</StackPanel>
							</Button>
							<!-- 模型选择器 -->
							<Button x:Name="ModelSelectorBtn" Classes="titlebar-btn" Padding="6,3"
									Click="OnModelSelectorClick">
								<StackPanel Orientation="Horizontal" Spacing="4">
									<Image Source="/Assets/model.png" Width="14" Height="14" />
									<TextBlock x:Name="ToolbarModelLabel" Text="模型"
											   Foreground="#a0a0a0" FontSize="12" />
									<TextBlock Text="▲" Foreground="#6a6a6a" FontSize="9"
											   VerticalAlignment="Center" />
								</StackPanel>
							</Button>
						</StackPanel>
						<StackPanel>
							<ProgressBar x:Name="AiProgressBar"
										 Minimum="0"
										 Maximum="100"
										 Value="0"
										 Height="1"
										 Margin="0,1,0,0"
										 Tag="0%  0k/ 0k"
										 ToolTip.Tip="{Binding Tag, RelativeSource={RelativeSource Self}}"
										 ToolTip.Placement="Top"
										 Foreground="{DynamicResource BlueBrush}"
										 Background="{DynamicResource Surface1Brush}" />
						</StackPanel>
						<!-- 选择器弹出面板：智能体 -->
						<Popup x:Name="AgentSelectorPopup" Placement="TopEdgeAlignedLeft"
							   PlacementTarget="{Binding #AgentSelectorBtn}"
							   IsLightDismissEnabled="True">
							<Border Background="#181818" CornerRadius="6"
									BorderBrush="#3c3c3c" BorderThickness="1"
									Padding="4" MinWidth="200" MaxHeight="300">
								<ScrollViewer VerticalScrollBarVisibility="Auto">
									<ItemsControl x:Name="AgentSelectorList">
										<ItemsControl.ItemsPanel>
											<ItemsPanelTemplate>
												<StackPanel Spacing="2" />
											</ItemsPanelTemplate>
										</ItemsControl.ItemsPanel>
									</ItemsControl>
								</ScrollViewer>
							</Border>
						</Popup>

						<!-- 选择器弹出面板：厂商 -->
						<Popup x:Name="ProviderPopup" Placement="TopEdgeAlignedLeft"
							   PlacementTarget="{Binding #ProviderSelectorBtn}"
							   IsLightDismissEnabled="True">
							<Border Background="#181818" CornerRadius="6"
									BorderBrush="#3c3c3c" BorderThickness="1"
									Padding="4" MinWidth="200" MaxHeight="300">
								<ScrollViewer VerticalScrollBarVisibility="Auto">
									<ItemsControl x:Name="ProviderList">
										<ItemsControl.ItemsPanel>
											<ItemsPanelTemplate>
												<StackPanel Spacing="2" />
											</ItemsPanelTemplate>
										</ItemsControl.ItemsPanel>
									</ItemsControl>
								</ScrollViewer>
							</Border>
						</Popup>

						<!-- 选择器弹出面板：模型 -->
						<Popup x:Name="ModelPopup" Placement="TopEdgeAlignedLeft"
							   PlacementTarget="{Binding #ModelSelectorBtn}"
							   IsLightDismissEnabled="True">
							<Border Background="#181818" CornerRadius="6"
									BorderBrush="#3c3c3c" BorderThickness="1"
									Padding="4" MinWidth="220" MaxHeight="360">
								<DockPanel>
									<TextBox x:Name="ModelSearchBox" DockPanel.Dock="Top"
											 PlaceholderText="搜索模型…" FontSize="12"
											 Margin="4,2,4,4" Classes="form-input"
											 TextChanged="OnModelSearchTextChanged" />
									<ScrollViewer VerticalScrollBarVisibility="Auto">
										<ItemsControl x:Name="ModelList">
											<ItemsControl.ItemsPanel>
												<ItemsPanelTemplate>
													<StackPanel Spacing="2" />
												</ItemsPanelTemplate>
											</ItemsControl.ItemsPanel>
										</ItemsControl>
									</ScrollViewer>
								</DockPanel>
							</Border>
						</Popup>
					</StackPanel>
				</Border>

				<!-- ── 消息列表 ── -->
				<Grid>
					<!-- 欢迎消息面板 -->
					<StackPanel x:Name="WelcomePanel"
								VerticalAlignment="Center" HorizontalAlignment="Center"
								Spacing="8">
						<Image Source="avares://Cortana/Assets/logo.300.png"
							   Width="180" Height="180"
							   Stretch="Uniform"
							   HorizontalAlignment="Center" />
						<TextBlock Text="你好，有什么可以帮你的？"
								   FontSize="18" FontWeight="SemiBold"
								   Foreground="#cccccc" HorizontalAlignment="Center" />
						<TextBlock Text="输入消息开始对话"
								   FontSize="13" Foreground="#6a6a6a"
								   HorizontalAlignment="Center" />
					</StackPanel>

					<!-- 消息滚动区域 -->
					<ScrollViewer x:Name="MessageScroller"
								  VerticalScrollBarVisibility="Auto"
								  HorizontalScrollBarVisibility="Disabled"
								  Background="Transparent">
						<ItemsControl x:Name="MessageList" Padding="16">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<StackPanel Spacing="20" />
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
						</ItemsControl>
					</ScrollViewer>

					<!-- 滚动到底部按钮 -->
					<Button x:Name="ScrollToBottomBtn"
							IsVisible="False"
							HorizontalAlignment="Right" VerticalAlignment="Bottom"
							Margin="0,0,16,8"
							Background="#252526" Foreground="#cccccc"
							BorderBrush="#3c3c3c" BorderThickness="1"
							CornerRadius="4" Padding="10,6"
							Cursor="Hand" FontSize="12"
							Click="OnScrollToBottomClick">
						<StackPanel Orientation="Horizontal" Spacing="4">
							<TextBlock Text="↓" FontSize="13" VerticalAlignment="Center" />
							<TextBlock Text="滚动到底" FontSize="12" VerticalAlignment="Center" />
						</StackPanel>
					</Button>
				</Grid>
				</DockPanel>
				<!-- 界面重设计 C4：主区 Tab 内容容器（决策 UI-1 L2 + DT-12）。
				     原 WorkflowTabContent (WorkspaceTab 整体) → WorkflowDetailView（仅右半，左半移到 LeftPanel.Tab2）；
				     原 GroupChatTabContent (EmptyState 占位) → WorkflowDetailView（与工作流共用同一个 DI Singleton VM，
				                                                  任务列表通过 LeftPanel.Tab2 共享，互斥显示）。
				     用户在工作流 / 群聊任意 tab 选中任务后，主区都会显示该任务详情。
				     C4 阶段：两个 Tab 共用同一个 VM 实例（决策 DT-9 SubMode 过滤推迟到 C5+，本期先跑通）。

				     详见 Docs/未来版本策划/界面重设计/04-实施阶段.md §4.3 + §4.5。 -->
				<workspace:WorkflowDetailView x:Name="WorkflowTabContent" IsVisible="False" />
				<workspace:WorkflowDetailView x:Name="GroupChatTabContent" IsVisible="False" />
				</Panel>
			</DockPanel>
		</Grid>
	</Panel>
</Window>
